# Cyrius build artifacts
/build/

# Vendored stdlib + dep snapshots — repopulated by `cyrius deps`
# from the version-pinned snapshot in cyrius.cyml [deps] stdlib +
# [deps.<name>]. Keeping this out of the repo prevents stale
# stubs from a prior cyrius version sitting in tree (matches
# yukti / patra / agnosys / agnostik convention).
/lib/

# Release / toolchain tarballs
cyrius-*.tar.gz
*.tar.gz
SHA256SUMS

# qemu-user core dumps — `qemu-aarch64` writes
# `qemu_<exe>_<ts>_<pid>.core` to cwd when an emulated binary
# segfaults. Common during 1.5.4+ aarch64 sweeps (the documented
# `audit_extended` known-failure under qemu segfaults at
# `persist: open succeeds`). Also catch the generic patterns so
# any future native core dumps don't sneak in.
qemu_*.core
core
core.*

# 1.6.0 PID-1 harness — `qemu/build-initramfs.sh` stages a tree
# under `qemu/initramfs/` and bundles it into `initramfs.cpio.gz`.
# Both are build outputs (argonaut binary + busybox + cpio); the
# checked-in shape lives in `qemu/build-initramfs.sh` only.
/qemu/initramfs/
/qemu/initramfs.cpio.gz

