# test_audit.cyr — Audit logging tests
# Parity target: 9 Rust tests from audit.rs
# Uses libro 1.0.2 SHA-256 hash-linked chain

include "src/test_header.cyr"

# Libro deps for audit
include "lib/freelist.cyr"
include "lib/bigint.cyr"
include "lib/chrono.cyr"
include "lib/sigil.cyr"
include "lib/error.cyr"
include "lib/hasher.cyr"
include "lib/entry.cyr"
include "lib/verify.cyr"
include "lib/query.cyr"
include "lib/retention.cyr"
include "lib/chain.cyr"

include "src/audit.cyr"

fn main() {
    alloc_init();
    println("=== Test Suite 9: Audit Logging ===");

    # --- 1. Record single event ---
    var log = audit_log_new();
    audit_log_record(log, "daimon", EVT_STARTING);
    assert_eq(audit_log_len(log), 1, "record: len 1");
    assert_eq(audit_log_is_empty(log) == 0, 1, "record: not empty");

    # --- 2. Multiple events + verify ---
    var log2 = audit_log_new();
    audit_log_record(log2, "daimon", EVT_STARTING);
    audit_log_record(log2, "daimon", EVT_STARTED);
    audit_log_record(log2, "daimon", EVT_HEALTH_PASSED);
    assert_eq(audit_log_len(log2), 3, "multi: len 3");
    assert_eq(audit_log_verify(log2), 1, "multi: chain valid");

    # --- 3. Severity mapping — Info events ---
    assert_eq(audit_event_severity(EVT_STARTING), SEV_INFO, "sev: starting info");
    assert_eq(audit_event_severity(EVT_STARTED), SEV_INFO, "sev: started info");
    assert_eq(audit_event_severity(EVT_HEALTH_PASSED), SEV_INFO, "sev: hc pass info");
    assert_eq(audit_event_severity(EVT_READY_PASSED), SEV_INFO, "sev: rc pass info");
    assert_eq(audit_event_severity(EVT_DEP_MET), SEV_INFO, "sev: dep met info");
    assert_eq(audit_event_severity(EVT_STOPPED_OK), SEV_INFO, "sev: stop 0 info");
    assert_eq(audit_event_severity(EVT_ENABLED), SEV_INFO, "sev: enabled info");
    assert_eq(audit_event_severity(EVT_DISABLED), SEV_INFO, "sev: disabled info");

    # --- 4. Severity mapping — Warning events ---
    assert_eq(audit_event_severity(EVT_STOPPING), SEV_WARNING, "sev: stopping warn");
    assert_eq(audit_event_severity(EVT_RESTARTING), SEV_WARNING, "sev: restart warn");
    assert_eq(audit_event_severity(EVT_DEP_WAITING), SEV_WARNING, "sev: dep wait warn");
    assert_eq(audit_event_severity(EVT_HEALTH_FAILED), SEV_WARNING, "sev: hc fail warn");
    assert_eq(audit_event_severity(EVT_READY_FAILED), SEV_WARNING, "sev: rc fail warn");

    # --- 5. Severity mapping — Error events ---
    assert_eq(audit_event_severity(EVT_TIMEOUT_KILLED), SEV_ERROR, "sev: timeout err");
    assert_eq(audit_event_severity(EVT_CRASH_DETECTED), SEV_ERROR, "sev: crash err");
    assert_eq(audit_event_severity(EVT_STOPPED_FAIL), SEV_ERROR, "sev: stop fail err");

    # --- 6. Query by source ---
    var log3 = audit_log_new();
    audit_log_record(log3, "daimon", EVT_STARTING);
    audit_log_record(log3, "redis", EVT_STARTING);
    var by_src = audit_log_by_source(log3, "argonaut");
    assert_eq(vec_len(by_src), 2, "by_source: all argonaut");

    # --- 7. Query by severity ---
    var log4 = audit_log_new();
    audit_log_record(log4, "daimon", EVT_STARTING);
    audit_log_record(log4, "daimon", EVT_TIMEOUT_KILLED);
    var errors = audit_log_by_severity(log4, SEV_ERROR);
    assert_eq(vec_len(errors), 1, "by_sev: 1 error");
    var infos = audit_log_by_severity(log4, SEV_INFO);
    assert_eq(vec_len(infos), 1, "by_sev: 1 info");

    # --- 8. Composite query (source + min severity) ---
    var log5 = audit_log_new();
    audit_log_record(log5, "daimon", EVT_STARTING);
    audit_log_record(log5, "daimon", EVT_TIMEOUT_KILLED);
    var filtered = audit_log_query(log5, "argonaut", SEV_ERROR);
    assert_eq(vec_len(filtered), 1, "query: 1 error from argonaut");

    # --- 9. Chain integrity over many entries ---
    var log6 = audit_log_new();
    for (var i = 0; i < 10; i = i + 1) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "svc-");
        str_builder_add_int(sb, i);
        audit_log_record(log6, str_data(str_builder_build(sb)), EVT_STARTING);
    }
    assert_eq(audit_log_len(log6), 10, "integrity: len 10");
    assert_eq(audit_log_verify(log6), 1, "integrity: chain valid");

    # --- Extra: chain linkage (libro SHA-256) ---
    var entries = audit_log_entries(log6);
    var e0 = vec_get(entries, 0);
    assert_eq(str_len(audit_entry_prev_hash(e0)), 0, "genesis: prev_hash empty");
    var e1 = vec_get(entries, 1);
    assert(str_eq(audit_entry_prev_hash(e1), audit_entry_hash(e0)), "link: e1 -> e0");

    # --- Extra: entry accessors ---
    assert_eq(audit_entry_severity(e0), SEV_INFO, "entry: severity");
    assert(str_eq(audit_entry_source(e0), str_from("argonaut")), "entry: source");
    assert(str_eq(audit_entry_action(e0), str_from("Starting")), "entry: action");
    assert_eq(str_len(audit_entry_timestamp(e0)), 20, "entry: ts len");
    assert_eq(str_len(audit_entry_hash(e0)), 64, "entry: hash len 64");

    # --- Extra: severity ordering (libro uses integer enum) ---
    assert(SEV_DEBUG < SEV_INFO, "order: debug < info");
    assert(SEV_INFO < SEV_WARNING, "order: info < warn");
    assert(SEV_WARNING < SEV_ERROR, "order: warn < err");
    assert(SEV_ERROR < SEV_CRITICAL, "order: err < crit");
    assert(SEV_CRITICAL < SEV_SECURITY, "order: crit < sec");

    # --- Extra: min severity filter ---
    var log7 = audit_log_new();
    audit_log_record(log7, "a", EVT_STARTING);
    audit_log_record(log7, "b", EVT_STOPPING);
    audit_log_record(log7, "c", EVT_TIMEOUT_KILLED);
    var warns_up = audit_log_by_min_severity(log7, SEV_WARNING);
    assert_eq(vec_len(warns_up), 2, "min_sev: 2 at warning+");
    var errs_up = audit_log_by_min_severity(log7, SEV_ERROR);
    assert_eq(vec_len(errs_up), 1, "min_sev: 1 at error+");

    # --- Extra: severity_as_str (libro capitalized) ---
    assert(streq(severity_as_str(SEV_DEBUG), "Debug"), "str: debug");
    assert(streq(severity_as_str(SEV_INFO), "Info"), "str: info");
    assert(streq(severity_as_str(SEV_WARNING), "Warning"), "str: warning");
    assert(streq(severity_as_str(SEV_ERROR), "Error"), "str: error");

    # --- Extra: event_type_str ---
    assert(streq(event_type_str(EVT_STARTING), "Starting"), "evt: Starting");
    assert(streq(event_type_str(EVT_TIMEOUT_KILLED), "TimeoutKilled"), "evt: TimeoutKilled");

    # --- Extra: individual entry SHA-256 verification ---
    assert_eq(entry_verify(e0), 1, "e0 sha256 verify");
    assert_eq(entry_verify(e1), 1, "e1 sha256 verify");

    var failures = assert_summary();
    return failures;
}
var r = main();
syscall(SYS_EXIT, r);
