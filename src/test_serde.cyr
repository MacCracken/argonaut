# test_serde.cyr — JSON serialization round-trip tests
# Uses inline struct definitions (derive processes before includes resolve)
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/json.cyr"
include "lib/assert.cyr"

# Mirror ArgonautStats layout (6 fields * 8 bytes = 48)
#derive(Serialize)
struct TStats { boot_mode; dur_ms; running; failed; restarts; complete; }

# Mirror RestartConfig layout (3 fields)
#derive(Serialize)
struct TRestart { max_restarts; base_delay; max_delay; }

# Mirror EdgeBootConfig layout (5 fields)
#derive(Serialize)
struct TEdgeCfg { readonly; luks; tpm; max_boot_ms; pcr; }

# Mirror FleetRegistration layout (7 fields)
#derive(Serialize)
struct TFleet { machine_id; hostname; mode_str; verity; luks; kernel_ver; mem_mb; }

# Mirror HealthCheckResult layout (6 fields)
#derive(Serialize)
struct THcResult { service; check_type; passed; latency_ms; message; checked_at; }

fn main() {
    alloc_init();
    println("=== Test Suite 8: Serde Round-trips ===");

    # --- TStats serialize ---
    var s = alloc(48);
    store64(s, 1);       # BOOT_DESKTOP
    store64(s + 8, 1234);
    store64(s + 16, 3);
    store64(s + 24, 1);
    store64(s + 32, 7);
    store64(s + 40, 1);
    var sb1 = str_builder_new();
    TStats_to_json(s, sb1);
    var json = str_builder_build(sb1);
    assert(str_contains(json, str_from("boot_mode")), "st has mode");
    assert(str_contains(json, str_from("dur_ms")), "st has dur");
    assert(str_contains(json, str_from("restarts")), "st has rest");
    assert(str_contains(json, str_from("complete")), "st has done");
    assert(str_contains(json, str_from("1234")), "st has 1234");

    # --- TStats round-trip ---
    var p1 = json_parse(json);
    var rt1 = TStats_from_json(p1);
    assert_eq(load64(rt1), 1, "st rt mode");
    assert_eq(load64(rt1 + 8), 1234, "st rt dur");
    assert_eq(load64(rt1 + 16), 3, "st rt run");
    assert_eq(load64(rt1 + 24), 1, "st rt fail");
    assert_eq(load64(rt1 + 32), 7, "st rt rest");
    assert_eq(load64(rt1 + 40), 1, "st rt done");

    # --- TRestart serialize + round-trip ---
    var rc = alloc(24);
    store64(rc, 5);
    store64(rc + 8, 1000);
    store64(rc + 16, 30000);
    var sb2 = str_builder_new();
    TRestart_to_json(rc, sb2);
    var rcj = str_builder_build(sb2);
    assert(str_contains(rcj, str_from("max_restarts")), "rc has max");
    assert(str_contains(rcj, str_from("base_delay")), "rc has base");
    var p2 = json_parse(rcj);
    var rt2 = TRestart_from_json(p2);
    assert_eq(load64(rt2), 5, "rc rt max");
    assert_eq(load64(rt2 + 8), 1000, "rc rt base");
    assert_eq(load64(rt2 + 16), 30000, "rc rt maxd");

    # --- TEdgeCfg serialize + round-trip ---
    var ec = alloc(40);
    store64(ec, 1);
    store64(ec + 8, 1);
    store64(ec + 16, 1);
    store64(ec + 24, 3000);
    store64(ec + 32, 0);
    var sb3 = str_builder_new();
    TEdgeCfg_to_json(ec, sb3);
    var ecj = str_builder_build(sb3);
    assert(str_contains(ecj, str_from("readonly")), "ec has ro");
    assert(str_contains(ecj, str_from("luks")), "ec has luks");
    assert(str_contains(ecj, str_from("3000")), "ec has 3k");
    var p3 = json_parse(ecj);
    var rt3 = TEdgeCfg_from_json(p3);
    assert_eq(load64(rt3), 1, "ec rt ro");
    assert_eq(load64(rt3 + 8), 1, "ec rt luks");
    assert_eq(load64(rt3 + 24), 3000, "ec rt boot");

    # --- TFleet serialize + round-trip ---
    var fr = alloc(56);
    store64(fr, 100);
    store64(fr + 8, 200);
    store64(fr + 16, 300);
    store64(fr + 24, 1);
    store64(fr + 32, 1);
    store64(fr + 40, 400);
    store64(fr + 48, 128);
    var sb4 = str_builder_new();
    TFleet_to_json(fr, sb4);
    var frj = str_builder_build(sb4);
    assert(str_contains(frj, str_from("machine_id")), "fr has mid");
    assert(str_contains(frj, str_from("hostname")), "fr has host");
    assert(str_contains(frj, str_from("128")), "fr has 128");
    var p4 = json_parse(frj);
    var rt4 = TFleet_from_json(p4);
    assert_eq(load64(rt4 + 24), 1, "fr rt verity");
    assert_eq(load64(rt4 + 48), 128, "fr rt mem");

    # --- Enum values survive ---
    var edge_s = alloc(48);
    store64(edge_s, 3);  # BOOT_EDGE
    var sb5 = str_builder_new();
    TStats_to_json(edge_s, sb5);
    var ej = str_builder_build(sb5);
    var p5 = json_parse(ej);
    var rt5 = TStats_from_json(p5);
    assert_eq(load64(rt5), 3, "enum edge rt");

    var rec_s = alloc(48);
    store64(rec_s, 4);  # BOOT_RECOVERY
    var sb6 = str_builder_new();
    TStats_to_json(rec_s, sb6);
    var rj = str_builder_build(sb6);
    var p6 = json_parse(rj);
    var rt6 = TStats_from_json(p6);
    assert_eq(load64(rt6), 4, "enum recovery rt");

    # --- Zero values ---
    var zero = alloc(48);
    memset(zero, 0, 48);
    var sb7 = str_builder_new();
    TStats_to_json(zero, sb7);
    var zj = str_builder_build(sb7);
    var p7 = json_parse(zj);
    var rt7 = TStats_from_json(p7);
    assert_eq(load64(rt7), 0, "zero mode rt");
    assert_eq(load64(rt7 + 8), 0, "zero dur rt");
    assert_eq(load64(rt7 + 40), 0, "zero done rt");

    # --- JSON parse/build ---
    var bp = json_parse(str_from("{\"name\":\"test\",\"value\":\"42\"}"));
    assert(json_get(bp, str_from("name")) != 0, "json get name");
    assert_eq(json_get_int(bp, str_from("value")), 42, "json get int");

    var bld = vec_new();
    vec_push(bld, json_pair_new(str_from("k1"), str_from("v1")));
    vec_push(bld, json_pair_new(str_from("k2"), str_from("v2")));
    var built = json_build(bld);
    assert(str_contains(built, str_from("k1")), "built k1");
    assert(str_contains(built, str_from("v1")), "built v1");

    # --- THcResult serialize ---
    var hcr = alloc(48);
    store64(hcr, 42);
    store64(hcr + 16, 1);
    store64(hcr + 24, 55);
    var sb8 = str_builder_new();
    THcResult_to_json(hcr, sb8);
    var hcrj = str_builder_build(sb8);
    assert(str_contains(hcrj, str_from("service")), "hcr has svc");
    assert(str_contains(hcrj, str_from("passed")), "hcr has pass");
    assert(str_contains(hcrj, str_from("latency_ms")), "hcr has lat");

    var failures = assert_summary();
    return failures;
}
var r = main();
syscall(SYS_EXIT, r);
