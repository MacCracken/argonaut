fn test_stats() {
    println("--- Stats ---");

    # Empty init
    var init = minimal_init();
    var s = init_stats(init);
    assert_eq(load64(s), BOOT_MINIMAL, "stats boot mode");
    assert_eq(load64(s + 16), 0, "stats 0 running");
    assert_eq(load64(s + 24), 0, "stats 0 failed");
    assert_eq(load64(s + 32), 0, "stats 0 restarts");
    assert_eq(load64(s + 40), 0, "stats not complete");

    # With services running
    var sinit = server_init();
    init_set_service_state(sinit, "postgres", STATE_STARTING);
    init_set_service_state(sinit, "postgres", STATE_RUNNING);
    init_set_service_state(sinit, "redis", STATE_STARTING);
    init_set_service_state(sinit, "redis", STATE_RUNNING);
    init_set_service_state(sinit, "daimon", STATE_STARTING);
    init_set_service_state(sinit, "daimon", STATE_RUNNING);
    var ss = init_stats(sinit);
    assert_eq(load64(ss + 16), 3, "stats 3 running");
}

