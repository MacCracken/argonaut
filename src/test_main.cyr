fn test_boot_step_status() {
    println("--- BootStepStatus ---");
    assert(streq(step_status_str(STEP_PENDING), "pending"), "step_status pending");
    assert(streq(step_status_str(STEP_RUNNING), "running"), "step_status running");
    assert(streq(step_status_str(STEP_COMPLETE), "complete"), "step_status complete");
