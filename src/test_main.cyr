# =========================================================================
# Boot sequence per mode
# =========================================================================

fn test_boot_sequence() {
    println("--- Boot Sequence ---");

    # Minimal
    var min_steps = build_boot_sequence(BOOT_MINIMAL);
    assert_eq(vec_len(min_steps), 6, "minimal step count");
    assert(steps_has_stage(min_steps, STAGE_AGENT_RUNTIME), "minimal has agent");
    assert(steps_has_stage(min_steps, STAGE_BOOT_COMPLETE), "minimal has complete");
    assert(steps_has_stage(min_steps, STAGE_MOUNT_FS), "minimal has mount");
    assert(1 - steps_has_stage(min_steps, STAGE_COMPOSITOR), "minimal no compositor");
    assert(1 - steps_has_stage(min_steps, STAGE_SHELL), "minimal no shell");
    assert(1 - steps_has_stage(min_steps, STAGE_LLM_GATEWAY), "minimal no llm");

    # Server
    var srv_steps = build_boot_sequence(BOOT_SERVER);
    assert_eq(vec_len(srv_steps), 9, "server step count");
    assert(1 - steps_has_stage(srv_steps, STAGE_COMPOSITOR), "server no compositor");
    assert(1 - steps_has_stage(srv_steps, STAGE_SHELL), "server no shell");
    assert(steps_has_stage(srv_steps, STAGE_LLM_GATEWAY), "server has llm");
    assert(steps_has_stage(srv_steps, STAGE_DATABASE), "server has database");

    # Desktop
    var dsk_steps = build_boot_sequence(BOOT_DESKTOP);
    assert_eq(vec_len(dsk_steps), 11, "desktop step count");
    assert(steps_has_stage(dsk_steps, STAGE_COMPOSITOR), "desktop has compositor");
    assert(steps_has_stage(dsk_steps, STAGE_SHELL), "desktop has shell");
    assert(steps_has_stage(dsk_steps, STAGE_LLM_GATEWAY), "desktop has llm");
    assert(steps_has_stage(dsk_steps, STAGE_BOOT_COMPLETE), "desktop has complete");

    # Edge
    var edge_steps = build_boot_sequence(BOOT_EDGE);
    assert_eq(vec_len(edge_steps), 6, "edge step count");
    assert(steps_has_stage(edge_steps, STAGE_AGENT_RUNTIME), "edge has agent");
    assert(1 - steps_has_stage(edge_steps, STAGE_DATABASE), "edge no database");
    assert(1 - steps_has_stage(edge_steps, STAGE_LLM_GATEWAY), "edge no llm");
    assert(1 - steps_has_stage(edge_steps, STAGE_COMPOSITOR), "edge no compositor");

    # Recovery
    var rec_steps = build_boot_sequence(BOOT_RECOVERY);
    assert_eq(vec_len(rec_steps), 5, "recovery step count");
    assert(steps_has_stage(rec_steps, STAGE_BOOT_COMPLETE), "recovery has complete");
    assert(1 - steps_has_stage(rec_steps, STAGE_AGENT_RUNTIME), "recovery no agent");

    # Edge fast timeouts
    for (var i = 0; i < vec_len(edge_steps); i = i + 1) {
        var step = vec_get(edge_steps, i);
        if (load64(step) == STAGE_AGENT_RUNTIME) {
            assert_eq(load64(step + 24), 3000, "edge agent timeout 3000ms");
        }
        if (load64(step) == STAGE_BOOT_COMPLETE) {
            assert_eq(load64(step + 24), 500, "edge complete timeout 500ms");
        }
    }

    # Desktop timeouts
    for (var i = 0; i < vec_len(dsk_steps); i = i + 1) {
        var step = vec_get(dsk_steps, i);
        if (load64(step) == STAGE_MOUNT_FS) {
            assert_eq(load64(step + 24), 2000, "desktop mount timeout 2000");
        }
        if (load64(step) == STAGE_VERIFY_ROOTFS) {
            assert_eq(load64(step + 24), 5000, "desktop verify timeout 5000");
        }
        if (load64(step) == STAGE_BOOT_COMPLETE) {
            assert_eq(load64(step + 24), 1000, "desktop complete timeout 1000");
        }
    }
}

# =========================================================================
# Default services tests
# =========================================================================

fn test_default_services() {
    println("--- Default Services ---");

    # Minimal
    var min_svcs = default_services(BOOT_MINIMAL);
    assert_eq(vec_len(min_svcs), 1, "minimal svc count");
    assert(streq(str_data(svc_def_name(vec_get(min_svcs, 0))), "daimon"), "minimal has daimon");

    # Server
    var srv_svcs = default_services(BOOT_SERVER);
    assert_eq(vec_len(srv_svcs), 5, "server svc count");
    assert(svcs_has_name(srv_svcs, "daimon"), "server has daimon");
    assert(svcs_has_name(srv_svcs, "llm-gateway"), "server has llm-gateway");
    assert(svcs_has_name(srv_svcs, "postgres"), "server has postgres");
    assert(svcs_has_name(srv_svcs, "redis"), "server has redis");
    assert(svcs_has_name(srv_svcs, "ifran"), "server has ifran");

    # Desktop
    var dsk_svcs = default_services(BOOT_DESKTOP);
    assert_eq(vec_len(dsk_svcs), 7, "desktop svc count");
    assert(svcs_has_name(dsk_svcs, "aethersafha"), "desktop has compositor");
    assert(svcs_has_name(dsk_svcs, "agnoshi"), "desktop has shell");
    assert(svcs_has_name(dsk_svcs, "ifran"), "desktop has ifran");

    # Edge
    var edge_svcs = default_services(BOOT_EDGE);
    assert_eq(vec_len(edge_svcs), 1, "edge svc count");
    assert(streq(str_data(svc_def_name(vec_get(edge_svcs, 0))), "daimon"), "edge has daimon");
    assert_eq(vec_len(svc_def_deps(vec_get(edge_svcs, 0))), 0, "edge daimon no deps");

    # Recovery
    var rec_svcs = default_services(BOOT_RECOVERY);
    assert_eq(vec_len(rec_svcs), 0, "recovery no services");

    # Minimal excludes databases
    assert(1 - svcs_has_name(min_svcs, "postgres"), "minimal no postgres");
    assert(1 - svcs_has_name(min_svcs, "redis"), "minimal no redis");

    # Edge excludes everything except daimon
    assert(1 - svcs_has_name(edge_svcs, "postgres"), "edge no postgres");
    assert(1 - svcs_has_name(edge_svcs, "llm-gateway"), "edge no llm-gw");
    assert(1 - svcs_has_name(edge_svcs, "aethersafha"), "edge no compositor");

    # Agent-runtime depends on databases in server mode
    for (var i = 0; i < vec_len(srv_svcs); i = i + 1) {
        var sd = vec_get(srv_svcs, i);
        if (streq(str_data(svc_def_name(sd)), "daimon")) {
            assert(vec_contains_str(svc_def_deps(sd), str_from("postgres")), "server daimon dep postgres");
            assert(vec_contains_str(svc_def_deps(sd), str_from("redis")), "server daimon dep redis");
        }
    }

    # Agent-runtime no db deps in minimal
    assert_eq(vec_len(svc_def_deps(vec_get(min_svcs, 0))), 0, "minimal daimon no deps");

    # Database service health checks
    var db_svcs = database_services();
    for (var i = 0; i < vec_len(db_svcs); i = i + 1) {
        var sd = vec_get(db_svcs, i);
        assert(svc_def_health_check(sd) != 0, "db svc has health check");
        assert(svc_def_ready_check(sd) != 0, "db svc has ready check");
    }

    # Database restart policies
    for (var i = 0; i < vec_len(db_svcs); i = i + 1) {
        var sd = vec_get(db_svcs, i);
        if (streq(str_data(svc_def_name(sd)), "redis")) {
            assert_eq(svc_def_restart_policy(sd), RESTART_ALWAYS, "redis restart always");
        }
        if (streq(str_data(svc_def_name(sd)), "postgres")) {
            assert_eq(svc_def_restart_policy(sd), RESTART_ON_FAILURE, "postgres restart on-failure");
        }
    }

    # Edge env vars
    var edge_daimon = vec_get(edge_svcs, 0);
    var edge_env = svc_def_env(edge_daimon);
    assert(map_has(edge_env, "AGNOS_EDGE_MODE"), "edge daimon has EDGE_MODE");
    assert(map_has(edge_env, "AGNOS_READONLY_ROOTFS"), "edge daimon has READONLY");

    # Ifran service
    var ifran = ifran_service();
    assert(streq(str_data(svc_def_name(ifran)), "ifran"), "ifran name");
    assert(vec_contains_str(svc_def_deps(ifran), str_from("daimon")), "ifran dep daimon");
    assert(vec_contains_str(svc_def_deps(ifran), str_from("llm-gateway")), "ifran dep llm-gw");
    assert(svc_def_health_check(ifran) != 0, "ifran has hc");
    assert(svc_def_ready_check(ifran) != 0, "ifran has rc");
}

# =========================================================================
# Dependency resolution tests
# =========================================================================

fn test_dependency_resolution() {
    println("--- Dependency Resolution ---");

    # Simple chain: a -> b -> c
    var chain = vec_new();
    var deps_c = vec_new();
    vec_push(deps_c, str_from("b"));
    vec_push(chain, dummy_service_def(str_from("c"), deps_c));
    var deps_b = vec_new();
    vec_push(deps_b, str_from("a"));
    vec_push(chain, dummy_service_def(str_from("b"), deps_b));
    vec_push(chain, dummy_service_def(str_from("a"), 0));

    var order = resolve_service_order(chain);
    assert(order != 0, "chain resolves");
    assert_eq(vec_len(order), 3, "chain length 3");
    assert_eq(order_pos(order, "a"), 0, "a first");
    assert_eq(order_pos(order, "b"), 1, "b second");
    assert_eq(order_pos(order, "c"), 2, "c third");

    # Independent services
    var indep = vec_new();
    vec_push(indep, dummy_service_def(str_from("alpha"), 0));
    vec_push(indep, dummy_service_def(str_from("beta"), 0));
    vec_push(indep, dummy_service_def(str_from("gamma"), 0));
    var indep_order = resolve_service_order(indep);
    assert(indep_order != 0, "independent resolves");
    assert_eq(vec_len(indep_order), 3, "independent length 3");

    # Cycle detection
    var cycle = vec_new();
    var deps_a2 = vec_new();
    vec_push(deps_a2, str_from("b"));
    vec_push(cycle, dummy_service_def(str_from("a"), deps_a2));
    var deps_b2 = vec_new();
    vec_push(deps_b2, str_from("a"));
    vec_push(cycle, dummy_service_def(str_from("b"), deps_b2));
    var cycle_order = resolve_service_order(cycle);
    assert_eq(cycle_order, 0, "cycle detected");

    # Desktop dependency ordering
    var dsk_svcs = default_services(BOOT_DESKTOP);
    var dsk_order = resolve_service_order(dsk_svcs);
    assert(dsk_order != 0, "desktop resolves");
    var rt_pos = order_pos(dsk_order, "daimon");
    var gw_pos = order_pos(dsk_order, "llm-gateway");
    var comp_pos = order_pos(dsk_order, "aethersafha");
    var shell_pos = order_pos(dsk_order, "agnoshi");
    var ifran_pos = order_pos(dsk_order, "ifran");
    assert(rt_pos < gw_pos, "daimon before llm-gw");
    assert(rt_pos < comp_pos, "daimon before compositor");
    assert(rt_pos < shell_pos, "daimon before shell");
    assert(comp_pos < shell_pos, "compositor before shell");
    assert(gw_pos < ifran_pos, "llm-gw before ifran");

    # Wave resolution
    var waves = resolve_service_waves(dsk_svcs);
    assert(waves != 0, "desktop waves resolve");
    assert(vec_len(waves) > 1, "desktop multiple waves");
}

# =========================================================================
# State transition tests
# =========================================================================

fn test_state_transitions() {
    println("--- State Transitions ---");

    # Valid transitions
    assert(valid_transition(STATE_STOPPED, STATE_STARTING), "stopped->starting");
    assert(valid_transition(STATE_STARTING, STATE_RUNNING), "starting->running");
    assert(valid_transition(STATE_STARTING, STATE_FAILED), "starting->failed");
    assert(valid_transition(STATE_RUNNING, STATE_STOPPING), "running->stopping");
    assert(valid_transition(STATE_RUNNING, STATE_FAILED), "running->failed");
    assert(valid_transition(STATE_STOPPING, STATE_STOPPED), "stopping->stopped");
    assert(valid_transition(STATE_STOPPING, STATE_FAILED), "stopping->failed");
    assert(valid_transition(STATE_FAILED, STATE_STARTING), "failed->starting");
    assert(valid_transition(STATE_FAILED, STATE_STOPPED), "failed->stopped");

    # Invalid transitions
    assert(1 - valid_transition(STATE_STOPPED, STATE_RUNNING), "stopped->running invalid");
    assert(1 - valid_transition(STATE_STOPPED, STATE_STOPPING), "stopped->stopping invalid");

    # Same state is valid
    assert(valid_transition(STATE_RUNNING, STATE_RUNNING), "same state valid");

    # Display
    assert(streq(service_state_str(STATE_STOPPED), "stopped"), "state_str stopped");
    assert(streq(service_state_str(STATE_RUNNING), "running"), "state_str running");
    assert(streq(service_state_str(STATE_FAILED), "failed"), "state_str failed");

    # Full lifecycle via init
    var init = minimal_init();
    assert(init_set_service_state(init, "daimon", STATE_STARTING), "init stopped->starting");
    assert_eq(init_get_service_state(init, "daimon"), STATE_STARTING, "state is starting");
    assert(init_set_service_state(init, "daimon", STATE_RUNNING), "init starting->running");
    assert_eq(init_get_service_state(init, "daimon"), STATE_RUNNING, "state is running");
    assert(init_set_service_state(init, "daimon", STATE_STOPPING), "init running->stopping");
    assert(init_set_service_state(init, "daimon", STATE_STOPPED), "init stopping->stopped");

    # Invalid: stopped -> running
    var init2 = minimal_init();
    assert(1 - init_set_service_state(init2, "daimon", STATE_RUNNING), "init stopped->running blocked");
    assert_eq(init_get_service_state(init2, "daimon"), STATE_STOPPED, "state still stopped");

    # Unknown service
    assert(1 - init_set_service_state(init2, "nonexistent", STATE_RUNNING), "unknown svc blocked");

    # Dependency blocking
    var sinit = server_init();
    assert(1 - init_set_service_state(sinit, "llm-gateway", STATE_STARTING), "llm-gw blocked by deps");
    # Start deps first
    init_set_service_state(sinit, "postgres", STATE_STARTING);
    init_set_service_state(sinit, "postgres", STATE_RUNNING);
    init_set_service_state(sinit, "redis", STATE_STARTING);
    init_set_service_state(sinit, "redis", STATE_RUNNING);
    init_set_service_state(sinit, "daimon", STATE_STARTING);
    # daimon still Starting, not Running
    assert(1 - init_set_service_state(sinit, "llm-gateway", STATE_STARTING), "llm-gw blocked daimon starting");
    init_set_service_state(sinit, "daimon", STATE_RUNNING);
    assert(init_set_service_state(sinit, "llm-gateway", STATE_STARTING), "llm-gw allowed after deps");
}

# =========================================================================
# Boot step marking tests
# =========================================================================

fn test_boot_step_marking() {
    println("--- Boot Step Marking ---");

    var init = minimal_init();

    # Mark complete
    assert(init_mark_step_complete(init, STAGE_MOUNT_FS), "mark mount complete");
    var steps = load64(init + 8);
    var step = vec_get(steps, 0);
    assert_eq(load64(step + 32), STEP_COMPLETE, "mount is complete");
    assert(load64(step + 48) > 0, "completed_at set");
    assert(load64(step + 40) > 0, "started_at set");

    # boot_started set after first step
    assert(load64(init + 24) > 0, "boot_started set");

    # Mark failed
    var init2 = minimal_init();
    assert(init_mark_step_failed(init2, STAGE_VERIFY_ROOTFS, str_from("dm-verity mismatch")), "mark verify failed");
    var steps2 = load64(init2 + 8);
    for (var i = 0; i < vec_len(steps2); i = i + 1) {
        var s = vec_get(steps2, i);
        if (load64(s) == STAGE_VERIFY_ROOTFS) {
            assert_eq(load64(s + 32), STEP_FAILED, "verify is failed");
            assert(load64(s + 56) != 0, "error msg set");
        }
    }
    assert(load64(init2 + 24) > 0, "boot_started set on fail");

    # Nonexistent stage
    assert(1 - init_mark_step_complete(init, STAGE_COMPOSITOR), "compositor not in minimal");

    # Current stage
    var init3 = minimal_init();
    var current = init_current_stage(init3);
    assert(current != 0, "current stage exists");
    assert_eq(load64(current), STAGE_MOUNT_FS, "current is mount");
    init_mark_step_complete(init3, STAGE_MOUNT_FS);
    var next = init_current_stage(init3);
    assert_eq(load64(next), STAGE_DEVICE_MGR, "next is device mgr");
}

# =========================================================================
# Boot complete tests
# =========================================================================

fn test_boot_complete() {
    println("--- Boot Complete ---");

    # All complete
    var init = minimal_init();
    var steps = load64(init + 8);
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        store64(vec_get(steps, i) + 32, STEP_COMPLETE);
    }
    assert(init_is_boot_complete(init), "all complete = boot complete");

    # Required failed = not complete
    var init2 = minimal_init();
    var steps2 = load64(init2 + 8);
    for (var i = 0; i < vec_len(steps2); i = i + 1) {
        var s = vec_get(steps2, i);
        if (load64(s + 16)) {  # required
            store64(s + 32, STEP_FAILED);
        } else {
            store64(s + 32, STEP_COMPLETE);
        }
    }
    assert(1 - init_is_boot_complete(init2), "required failed = not complete");

    # Optional failed = still complete
    var dinit = desktop_init();
    var dsteps = load64(dinit + 8);
    for (var i = 0; i < vec_len(dsteps); i = i + 1) {
        var s = vec_get(dsteps, i);
        if (load64(s + 16)) {
            store64(s + 32, STEP_COMPLETE);
        } else {
            store64(s + 32, STEP_FAILED);
        }
    }
    assert(init_is_boot_complete(dinit), "optional failed = boot complete");

    # Boot duration
    var init3 = minimal_init();
    store64(init3 + 24, 1000);
    store64(init3 + 32, 2234);
    assert_eq(init_boot_duration_ms(init3), 1234, "boot duration 1234ms");

    # Not complete = 0 duration
    var init4 = minimal_init();
    assert_eq(init_boot_duration_ms(init4), 0, "no duration before complete");

    # Failed steps list
    var init5 = minimal_init();
    init_mark_step_failed(init5, STAGE_VERIFY_ROOTFS, str_from("bad hash"));
    init_mark_step_failed(init5, STAGE_SECURITY, str_from("seccomp err"));
    var failed = init_failed_steps(init5);
    assert_eq(vec_len(failed), 2, "2 failed steps");
}

