# =========================================================================
# Notify message parsing tests
# =========================================================================

fn test_notify() {
    println("--- Notify ---");

    # Parse ready message
    var data1 = "READY=1\nSTATUS=running\n";
    var msg1 = notify_parse(data1, strlen(data1));
    assert_eq(load64(msg1), 1, "ready=1");
    assert(load64(msg1 + 8) != 0, "status set");
    assert_eq(load64(msg1 + 24), 0, "watchdog=0");

    # Parse watchdog
    var data2 = "WATCHDOG=1\n";
    var msg2 = notify_parse(data2, strlen(data2));
    assert_eq(load64(msg2 + 24), 1, "watchdog=1");
    assert_eq(load64(msg2), 0, "not ready");

    # Parse MAINPID
    var data3 = "READY=1\nMAINPID=42\n";
    var msg3 = notify_parse(data3, strlen(data3));
    assert_eq(load64(msg3), 1, "ready with mainpid");
    assert_eq(load64(msg3 + 16), 42, "mainpid=42");

    # Parse empty
    var msg4 = notify_parse("", 0);
    assert_eq(load64(msg4), 0, "empty not ready");

    # Parse reloading
    var data5 = "RELOADING=1\n";
    var msg5 = notify_parse(data5, strlen(data5));
    assert_eq(load64(msg5 + 32), 1, "reloading=1");

    # Parse stopping
    var data6 = "STOPPING=1\n";
    var msg6 = notify_parse(data6, strlen(data6));
    assert_eq(load64(msg6 + 40), 1, "stopping=1");

    # All fields
    var data7 = "READY=1\nWATCHDOG=1\nRELOADING=1\nSTOPPING=1\nSTATUS=all\nMAINPID=99\n";
    var msg7 = notify_parse(data7, strlen(data7));
    assert_eq(load64(msg7), 1, "all:ready");
    assert_eq(load64(msg7 + 24), 1, "all:watchdog");
    assert_eq(load64(msg7 + 32), 1, "all:reloading");
    assert_eq(load64(msg7 + 40), 1, "all:stopping");
    assert_eq(load64(msg7 + 16), 99, "all:mainpid");
}

# =========================================================================
# Security tests
# =========================================================================

fn test_security() {
    println("--- Security ---");

    # Seccomp description
    var basic_desc = seccomp_description(0, 0, 0);
    assert(str_contains(basic_desc, str_from("basic filter")), "basic seccomp desc");

    var custom_desc = seccomp_description(1, 2, 1);
    assert(str_contains(custom_desc, str_from("2 syscalls")), "custom allow count");
    assert(str_contains(custom_desc, str_from("1 explicit")), "custom deny count");

    # Landlock access display
    assert(streq(landlock_access_str(LL_NO_ACCESS), "none"), "ll none");
    assert(streq(landlock_access_str(LL_READ_ONLY), "ro"), "ll ro");
    assert(streq(landlock_access_str(LL_READ_WRITE), "rw"), "ll rw");

    # Capability display
    assert(streq(capability_str(CAP_SYS_ADMIN), "cap_sys_admin"), "cap sys_admin");
    assert(streq(capability_str(CAP_NET_BIND_SERVICE), "cap_net_bind_service"), "cap net_bind");
    assert(streq(capability_str(CAP_KILL), "cap_kill"), "cap kill");

    # Constant time eq
    assert(constant_time_eq("hello", 5, "hello", 5), "ct eq same");
    assert(1 - constant_time_eq("hello", 5, "world", 5), "ct eq different");
    assert(1 - constant_time_eq("short", 5, "longer", 6), "ct eq diff len");

    # Emergency auth - not required
    var esc = emergency_shell_default();
    assert(verify_emergency_auth(esc, str_from("anything")), "auth not required");

    # Capability setpriv command
    var caps = vec_new();
    vec_push(caps, CAP_SYS_ADMIN);
    vec_push(caps, CAP_NET_RAW);
    var cmd = capability_setpriv_cmd(caps, str_from("/usr/bin/myapp"), vec_new());
    assert(streq(str_data(safe_cmd_binary(cmd)), "setpriv"), "setpriv binary");
}

# =========================================================================
# Systemd unit generation tests
# =========================================================================

fn test_systemd() {
    println("--- Systemd Unit Gen ---");

    var sd = svc_def_new(str_from("myapp"), str_from("Test service myapp"), str_from("/usr/bin/myapp"));
    vec_push(svc_def_modes(sd), BOOT_SERVER);
    var unit = generate_unit(sd);
    assert(str_contains(unit, str_from("[Unit]")), "unit has [Unit]");
    assert(str_contains(unit, str_from("[Service]")), "unit has [Service]");
    assert(str_contains(unit, str_from("Type=notify")), "unit has Type=notify");
    assert(str_contains(unit, str_from("ExecStart=/usr/bin/myapp")), "unit has ExecStart");
    assert(str_contains(unit, str_from("Restart=on-failure")), "unit has Restart");
    assert(str_contains(unit, str_from("[Install]")), "unit has [Install]");
    assert(str_contains(unit, str_from("WantedBy=multi-user.target")), "unit multi-user target");

    # Desktop target
    var sd2 = svc_def_new(str_from("guiapp"), str_from("GUI app"), str_from("/usr/bin/guiapp"));
    vec_push(svc_def_modes(sd2), BOOT_DESKTOP);
    var unit2 = generate_unit(sd2);
    assert(str_contains(unit2, str_from("WantedBy=graphical.target")), "unit graphical target");

    # With dependencies
    var sd3 = svc_def_new(str_from("backend"), str_from("Backend"), str_from("/usr/bin/backend"));
    vec_push(svc_def_deps(sd3), str_from("postgres"));
    vec_push(svc_def_deps(sd3), str_from("redis"));
    var unit3 = generate_unit(sd3);
    assert(str_contains(unit3, str_from("After=")), "unit has After");
    assert(str_contains(unit3, str_from("Requires=")), "unit has Requires");

    # With args
    var sd4 = svc_def_new(str_from("withargs"), str_from("Args"), str_from("/usr/bin/withargs"));
    vec_push(svc_def_args(sd4), str_from("--port"));
    vec_push(svc_def_args(sd4), str_from("8080"));
    var unit4 = generate_unit(sd4);
    assert(str_contains(unit4, str_from("--port")), "unit has args");

    # Restart always
    var sd5 = svc_def_new(str_from("always"), str_from("Always"), str_from("/usr/bin/always"));
    store64(sd5 + 56, RESTART_ALWAYS);
    var unit5 = generate_unit(sd5);
    assert(str_contains(unit5, str_from("Restart=always")), "unit restart always");

    # Restart never
    var sd6 = svc_def_new(str_from("never"), str_from("Never"), str_from("/usr/bin/never"));
    store64(sd6 + 56, RESTART_NEVER);
    var unit6 = generate_unit(sd6);
    assert(str_contains(unit6, str_from("Restart=no")), "unit restart no");

    # Filename
    var fname = generate_unit_filename(sd);
    assert(str_contains(fname, str_from("myapp.service")), "unit filename");
}

# =========================================================================
# Tmpfiles tests
# =========================================================================

fn test_tmpfiles() {
    println("--- Tmpfiles ---");

    # Directory entry
    var entries = vec_new();
    var dir_entry = alloc(72);
    store64(dir_entry, TMP_DIRECTORY);
    store64(dir_entry + 8, str_from("/run/myapp"));
    store64(dir_entry + 24, 755);
    store64(dir_entry + 32, 0 - 1);  # uid not set
    store64(dir_entry + 40, 0 - 1);  # gid not set
    vec_push(entries, dir_entry);

    var cmds = generate_tmpfile_commands(entries);
    assert_eq(vec_len(cmds), 1, "dir generates 1 cmd");
    assert(streq(str_data(safe_cmd_binary(vec_get(cmds, 0))), "mkdir"), "dir cmd is mkdir");

    # Validation: absolute path required
    var bad_entries = vec_new();
    var bad = alloc(72);
    store64(bad, TMP_DIRECTORY);
    store64(bad + 8, str_from("relative/path"));
    store64(bad + 24, 755);
    vec_push(bad_entries, bad);
    assert_eq(validate_tmpfile_entries(bad_entries), 0 - 1, "relative path fails");

    # Validation: path traversal
    var trav_entries = vec_new();
    var trav = alloc(72);
    store64(trav, TMP_DIRECTORY);
    store64(trav + 8, str_from("/var/../etc/shadow"));
    store64(trav + 24, 755);
    vec_push(trav_entries, trav);
    assert_eq(validate_tmpfile_entries(trav_entries), 0 - 1, "traversal fails");

    # Valid entries pass
    var ok_entries = vec_new();
    var ok = alloc(72);
    store64(ok, TMP_DIRECTORY);
    store64(ok + 8, str_from("/run/myapp"));
    store64(ok + 24, 755);
    vec_push(ok_entries, ok);
    assert_eq(validate_tmpfile_entries(ok_entries), 0, "valid entry passes");
}

# =========================================================================
# Service name validation tests
# =========================================================================

fn test_service_name_validation() {
    println("--- Service Name Validation ---");

    assert(validate_service_name(str_from("daimon")), "valid: daimon");
    assert(validate_service_name(str_from("llm-gateway")), "valid: llm-gateway");
    assert(validate_service_name(str_from("svc_1")), "valid: svc_1");
    assert(validate_service_name(str_from("my.service")), "valid: my.service");
    assert(1 - validate_service_name(str_from("")), "invalid: empty");
    assert(1 - validate_service_name(str_from("a..b")), "invalid: traversal");
}

# =========================================================================
# Health history tests
# =========================================================================

fn test_health_history() {
    println("--- Health History ---");

    var hh = health_history_new(10);
    assert_eq(health_history_state(hh), HS_UNKNOWN, "initial unknown");
    assert_eq(health_history_len(hh), 0, "initial empty");
    assert_eq(health_history_failures(hh), 0, "initial 0 failures");

    # Pass -> healthy
    var r1 = alloc(48);
    store64(r1 + 16, 1);  # passed
    health_history_record(hh, r1, 3);
    assert_eq(health_history_state(hh), HS_HEALTHY, "pass -> healthy");
    assert_eq(health_history_failures(hh), 0, "pass 0 failures");
    assert_eq(health_history_len(hh), 1, "1 entry");

    # Fail -> degraded
    var r2 = alloc(48);
    store64(r2 + 16, 0);  # failed
    health_history_record(hh, r2, 3);
    assert_eq(health_history_state(hh), HS_DEGRADED, "1 fail -> degraded");
    assert_eq(health_history_failures(hh), 1, "1 failure");

    # 3 fails -> unhealthy
    health_history_record(hh, r2, 3);
    health_history_record(hh, r2, 3);
    assert_eq(health_history_state(hh), HS_UNHEALTHY, "3 fail -> unhealthy");
    assert_eq(health_history_failures(hh), 3, "3 failures");

    # Pass resets
    health_history_record(hh, r1, 3);
    assert_eq(health_history_state(hh), HS_HEALTHY, "pass resets to healthy");
    assert_eq(health_history_failures(hh), 0, "pass resets failures");

    # Ring buffer wraps
    var hh2 = health_history_new(3);
    for (var i = 0; i < 5; i = i + 1) {
        health_history_record(hh2, r1, 3);
    }
    assert_eq(health_history_len(hh2), 3, "ring capped at 3");
    assert_eq(health_history_total(hh2), 5, "total 5");

    # Reset clears all
    health_history_reset(hh);
    assert_eq(health_history_state(hh), HS_UNKNOWN, "reset -> unknown");
    assert_eq(health_history_len(hh), 0, "reset -> empty");
    assert_eq(health_history_failures(hh), 0, "reset -> 0 failures");
    assert_eq(health_history_total(hh), 0, "reset -> 0 total");
}

# =========================================================================
# Edge boot init tests
# =========================================================================

fn test_edge_init() {
    println("--- Edge Init ---");

    var init = edge_init();
    var svc_map = load64(init + 16);
    assert_eq(map_count(svc_map), 1, "edge 1 service");
    assert(map_has(svc_map, "daimon"), "edge has daimon");

    # Edge boot can complete
    var steps = load64(init + 8);
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        store64(vec_get(steps, i) + 32, STEP_COMPLETE);
    }
    assert(init_is_boot_complete(init), "edge boot completes");

    # Edge state lifecycle
    var init2 = edge_init();
    init_set_service_state(init2, "daimon", STATE_STARTING);
    init_set_service_state(init2, "daimon", STATE_RUNNING);
    var stats = init_stats(init2);
    assert_eq(load64(stats), BOOT_EDGE, "edge stats mode");
    assert_eq(load64(stats + 16), 1, "edge 1 running");
}

# =========================================================================
# Entry point
# =========================================================================

fn main() {
    alloc_init();
    println("=== Argonaut Test Suite ===\n");

    test_boot_mode();
    test_boot_stage();
    test_boot_step_status();
    test_restart_policy();
    test_boot_sequence();
    test_default_services();
    test_dependency_resolution();
    test_state_transitions();
    test_boot_step_marking();
    test_boot_complete();
    test_stats();
    test_managed_service();
    test_restart_config();
    test_crash_actions();
    test_shutdown();
    test_runlevels();
    test_health_tracker();
    test_service_targets();
    test_edge_boot_config();
    test_config_defaults();
    test_emergency_shell();
    test_readonly_rootfs();
    test_dm_verity();
    test_device_path_validation();
    test_luks();
    test_notify();
    test_security();
    test_systemd();
    test_tmpfiles();
    test_service_name_validation();
    test_health_history();
    test_edge_init();

    var failures = assert_summary();
    return failures;
}

var r = main();
syscall(SYS_EXIT, r);
