# =========================================================================
# Helpers
# =========================================================================

fn minimal_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_MINIMAL);
    return argonaut_init_new(cfg);
}

fn server_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_SERVER);
    return argonaut_init_new(cfg);
}

fn desktop_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_DESKTOP);
    return argonaut_init_new(cfg);
}

fn edge_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_EDGE);
    return argonaut_init_new(cfg);
}

fn recovery_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_RECOVERY);
    return argonaut_init_new(cfg);
}

fn dummy_service_def(name, deps) {
    var sd = svc_def_new(name, str_cat(str_from("test service "), name), str_cat(str_from("/usr/bin/"), name));
    store64(sd + 56, RESTART_NEVER);
    vec_push(svc_def_modes(sd), BOOT_MINIMAL);
    store64(sd + 88, 1);  # enabled
    if (deps != 0) {
        for (var i = 0; i < vec_len(deps); i = i + 1) {
            vec_push(svc_def_deps(sd), vec_get(deps, i));
        }
    }
    return sd;
}

fn vec_contains_str(v, s) {
    var target = str_data(s);
    for (var i = 0; i < vec_len(v); i = i + 1) {
        var item = vec_get(v, i);
        # item might be a Str ptr or a cstr
        if (streq(str_data(item), target)) { return 1; }
    }
    return 0;
}

fn steps_has_stage(steps, stage) {
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        var step = vec_get(steps, i);
        if (load64(step) == stage) { return 1; }
    }
    return 0;
}

fn svcs_has_name(svcs, name) {
    for (var i = 0; i < vec_len(svcs); i = i + 1) {
        var sd = vec_get(svcs, i);
        if (streq(str_data(svc_def_name(sd)), name)) { return 1; }
    }
    return 0;
}

fn order_pos(order, name) {
    for (var i = 0; i < vec_len(order); i = i + 1) {
        if (streq(str_data(vec_get(order, i)), name)) { return i; }
    }
    return 0 - 1;
}

# =========================================================================
# BootMode tests
# =========================================================================

fn test_boot_mode() {
    println("--- BootMode ---");
    assert(streq(boot_mode_str(BOOT_SERVER), "server"), "boot_mode_str server");
    assert(streq(boot_mode_str(BOOT_DESKTOP), "desktop"), "boot_mode_str desktop");
    assert(streq(boot_mode_str(BOOT_MINIMAL), "minimal"), "boot_mode_str minimal");
    assert(streq(boot_mode_str(BOOT_EDGE), "edge"), "boot_mode_str edge");
    assert(streq(boot_mode_str(BOOT_RECOVERY), "recovery"), "boot_mode_str recovery");
}

# =========================================================================
# BootStage tests
# =========================================================================

fn test_boot_stage() {
    println("--- BootStage ---");
    # Ordering (enum values are sequential 0..10)
    assert(STAGE_MOUNT_FS < STAGE_DEVICE_MGR, "stage order mount < device");
    assert(STAGE_DEVICE_MGR < STAGE_VERIFY_ROOTFS, "stage order device < verify");
    assert(STAGE_VERIFY_ROOTFS < STAGE_SECURITY, "stage order verify < security");
    assert(STAGE_SECURITY < STAGE_DATABASE, "stage order security < database");
    assert(STAGE_DATABASE < STAGE_AGENT_RUNTIME, "stage order database < agent");
    assert(STAGE_AGENT_RUNTIME < STAGE_LLM_GATEWAY, "stage order agent < llm");
    assert(STAGE_LLM_GATEWAY < STAGE_MODEL_SERVICES, "stage order llm < model");
    assert(STAGE_MODEL_SERVICES < STAGE_COMPOSITOR, "stage order model < compositor");
    assert(STAGE_COMPOSITOR < STAGE_SHELL, "stage order compositor < shell");
    assert(STAGE_SHELL < STAGE_BOOT_COMPLETE, "stage order shell < complete");

    # Display
    assert(streq(boot_stage_str(STAGE_MOUNT_FS), "mount-filesystems"), "stage_str mount");
    assert(streq(boot_stage_str(STAGE_BOOT_COMPLETE), "boot-complete"), "stage_str complete");
    assert(streq(boot_stage_str(STAGE_DATABASE), "start-database-services"), "stage_str database");
}

# =========================================================================
# BootStepStatus tests
