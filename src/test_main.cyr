# =========================================================================
# Restart config tests
# =========================================================================

fn test_restart_config() {
    println("--- RestartConfig ---");

    var rc = restart_config_default();

    # Exponential backoff
    assert_eq(backoff_delay(rc, 0), 1000, "backoff 0 = 1000");
    assert_eq(backoff_delay(rc, 1), 2000, "backoff 1 = 2000");
    assert_eq(backoff_delay(rc, 2), 4000, "backoff 2 = 4000");
    assert_eq(backoff_delay(rc, 3), 8000, "backoff 3 = 8000");
    assert_eq(backoff_delay(rc, 4), 16000, "backoff 4 = 16000");
    assert_eq(backoff_delay(rc, 5), 30000, "backoff 5 capped at 30000");
    assert_eq(backoff_delay(rc, 10), 30000, "backoff 10 capped");

    # Limit exceeded
    assert(1 - restart_limit_exceeded(rc, 0), "limit not exceeded 0");
    assert(1 - restart_limit_exceeded(rc, 4), "limit not exceeded 4");
    assert(restart_limit_exceeded(rc, 5), "limit exceeded 5");
    assert(restart_limit_exceeded(rc, 10), "limit exceeded 10");

    # Zero means unlimited
    var rc0 = alloc(24);
    store64(rc0, 0);
    store64(rc0 + 8, 1000);
    store64(rc0 + 16, 30000);
    assert(1 - restart_limit_exceeded(rc0, 0), "unlimited 0");
    assert(1 - restart_limit_exceeded(rc0, 100), "unlimited 100");

    # Custom config backoff
    var rcc = alloc(24);
    store64(rcc, 3);
    store64(rcc + 8, 500);
    store64(rcc + 16, 10000);
    assert_eq(backoff_delay(rcc, 0), 500, "custom backoff 0");
    assert_eq(backoff_delay(rcc, 1), 1000, "custom backoff 1");
    assert_eq(backoff_delay(rcc, 2), 2000, "custom backoff 2");
    assert_eq(backoff_delay(rcc, 5), 10000, "custom backoff capped");
}

# =========================================================================
# Crash action tests
# =========================================================================

fn test_crash_actions() {
    println("--- Crash Actions ---");

    # Always restart policy restarts on crash
    var init = minimal_init();
    var ms = init_get_service(init, "daimon");
    var action = on_service_crash(ms, 1);
    assert_eq(load64(action), CRASH_RESTART, "always policy restarts");

    # OnFailure ignores clean exit
    var sinit = server_init();
    var pg = init_get_service(sinit, "postgres");
    var act2 = on_service_crash(pg, 0);
    assert_eq(load64(act2), CRASH_IGNORE, "on-failure ignores exit 0");

    # OnFailure restarts on error
    var act3 = on_service_crash(pg, 1);
    assert_eq(load64(act3), CRASH_RESTART, "on-failure restarts exit 1");

    # Gives up after limit
    var init2 = minimal_init();
    var ms2 = init_get_service(init2, "daimon");
    managed_svc_set_restarts(ms2, 5);
    var act4 = on_service_crash(ms2, 11);
    assert_eq(load64(act4), CRASH_GIVE_UP, "gives up after limit");
}

# =========================================================================
# Shutdown plan tests
# =========================================================================

fn test_shutdown() {
    println("--- Shutdown ---");

    var init = desktop_init();
    var plan = init_plan_shutdown(init, SHUTDOWN_REBOOT);
    assert_eq(load64(plan), SHUTDOWN_REBOOT, "plan type reboot");
    var steps = load64(plan + 8);
    assert(vec_len(steps) > 0, "plan has steps");

    # Last step is kernel action
    var last = vec_get(steps, vec_len(steps) - 1);
    assert_eq(load64(last + 8), SA_KERNEL_ACTION, "last step kernel action");

    # Has sync
    var has_sync = 0;
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        if (load64(vec_get(steps, i) + 8) == SA_SYNC_FS) { has_sync = 1; }
    }
    assert(has_sync, "plan has sync");

    # Has unmount
    var has_umount = 0;
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        if (load64(vec_get(steps, i) + 8) == SA_UNMOUNT_FS) { has_umount = 1; }
    }
    assert(has_umount, "plan has unmount");

    # Has LUKS close
    var has_luks = 0;
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        if (load64(vec_get(steps, i) + 8) == SA_CLOSE_LUKS) { has_luks = 1; }
    }
    assert(has_luks, "plan has LUKS close");

    # Has wall message
    assert(load64(plan + 24) != 0, "plan has wall message");

    # Shutdown type display
    assert(streq(shutdown_type_str(SHUTDOWN_POWEROFF), "poweroff"), "shutdown_str poweroff");
    assert(streq(shutdown_type_str(SHUTDOWN_REBOOT), "reboot"), "shutdown_str reboot");
    assert(streq(shutdown_type_str(SHUTDOWN_HALT), "halt"), "shutdown_str halt");
    assert(streq(shutdown_type_str(SHUTDOWN_KEXEC), "kexec"), "shutdown_str kexec");

    # Shutdown order is reverse of startup
    var defs = vec_new();
    var svc_map = load64(init + 16);
    var keys = map_keys(svc_map);
    for (var i = 0; i < vec_len(keys); i = i + 1) {
        var ms = map_get(svc_map, vec_get(keys, i));
        vec_push(defs, managed_svc_def(ms));
    }
    var startup = resolve_service_order(defs);
    assert(startup != 0, "startup order resolves");
}

# =========================================================================
# Runlevel tests
# =========================================================================

fn test_runlevels() {
    println("--- Runlevels ---");

    # To boot mode
    assert_eq(runlevel_to_boot_mode(RL_CONSOLE), BOOT_SERVER, "console->server");
    assert_eq(runlevel_to_boot_mode(RL_GRAPHICAL), BOOT_DESKTOP, "graphical->desktop");
    assert_eq(runlevel_to_boot_mode(RL_CONTAINER), BOOT_MINIMAL, "container->minimal");
    assert_eq(runlevel_to_boot_mode(RL_EDGE), BOOT_EDGE, "edge->edge");
    assert_eq(runlevel_to_boot_mode(RL_EMERGENCY), 0 - 1, "emergency->none");
    assert_eq(runlevel_to_boot_mode(RL_RESCUE), 0 - 1, "rescue->none");

    # From boot mode
    assert_eq(boot_mode_to_runlevel(BOOT_SERVER), RL_CONSOLE, "server->console");
    assert_eq(boot_mode_to_runlevel(BOOT_DESKTOP), RL_GRAPHICAL, "desktop->graphical");
    assert_eq(boot_mode_to_runlevel(BOOT_MINIMAL), RL_CONTAINER, "minimal->container");
    assert_eq(boot_mode_to_runlevel(BOOT_EDGE), RL_EDGE, "edge->edge");

    # Levels
    assert_eq(runlevel_level(RL_EMERGENCY), 0, "emergency level 0");
    assert_eq(runlevel_level(RL_RESCUE), 1, "rescue level 1");
    assert_eq(runlevel_level(RL_CONSOLE), 3, "console level 3");
    assert_eq(runlevel_level(RL_GRAPHICAL), 5, "graphical level 5");
    assert_eq(runlevel_level(RL_CONTAINER), 7, "container level 7");
    assert_eq(runlevel_level(RL_EDGE), 8, "edge level 8");

    # Display
    assert(streq(runlevel_str(RL_EMERGENCY), "emergency"), "rl_str emergency");
    assert(streq(runlevel_str(RL_CONSOLE), "console"), "rl_str console");
    assert(streq(runlevel_str(RL_GRAPHICAL), "graphical"), "rl_str graphical");
    assert(streq(runlevel_str(RL_EDGE), "edge"), "rl_str edge");

    # Runlevel switch: emergency stops all
    var minit = minimal_init();
    init_set_service_state(minit, "daimon", STATE_STARTING);
    init_set_service_state(minit, "daimon", STATE_RUNNING);
    var targets = default_targets();
    var eplan = init_plan_runlevel_switch(minit, RL_EMERGENCY, targets);
    assert(load64(eplan + 32), "emergency drops to shell");
    assert_eq(vec_len(load64(eplan + 16)), 0, "emergency starts nothing");
    assert(vec_len(load64(eplan + 24)) > 0, "emergency stops services");

    # Rescue drops to shell
    var dinit = desktop_init();
    var rplan = init_plan_runlevel_switch(dinit, RL_RESCUE, targets);
    assert(load64(rplan + 32), "rescue drops to shell");
}

# =========================================================================
# Health tracker tests
# =========================================================================

fn test_health_tracker() {
    println("--- Health Tracker ---");

    var tracker = health_tracker_new();

    # Pass resets
    var r1 = health_tracker_record(tracker, "svc1", 1, 3);
    assert_eq(r1, 0, "pass no restart");
    assert_eq(health_tracker_count(tracker, "svc1"), 0, "pass count 0");

    # Failures accumulate
    var r2 = health_tracker_record(tracker, "svc1", 0, 3);
    assert_eq(r2, 0, "1 fail no restart");
    assert_eq(health_tracker_count(tracker, "svc1"), 1, "fail count 1");

    var r3 = health_tracker_record(tracker, "svc1", 0, 3);
    assert_eq(r3, 0, "2 fail no restart");

    var r4 = health_tracker_record(tracker, "svc1", 0, 3);
    assert(r4, "3 fail triggers restart");
    assert_eq(health_tracker_count(tracker, "svc1"), 3, "fail count 3");

    # Pass resets counter
    health_tracker_record(tracker, "svc1", 1, 3);
    assert_eq(health_tracker_count(tracker, "svc1"), 0, "pass resets to 0");

    # Manual reset
    health_tracker_record(tracker, "svc2", 0, 3);
    health_tracker_record(tracker, "svc2", 0, 3);
    health_tracker_reset(tracker, "svc2");
    assert_eq(health_tracker_count(tracker, "svc2"), 0, "manual reset");

    # Independent services
    var t2 = health_tracker_new();
    health_tracker_record(t2, "svc1", 0, 2);
    health_tracker_record(t2, "svc2", 0, 2);
    assert_eq(health_tracker_count(t2, "svc1"), 1, "svc1 count 1");
    assert_eq(health_tracker_count(t2, "svc2"), 1, "svc2 count 1");
    assert(health_tracker_record(t2, "svc1", 0, 2), "svc1 threshold");
    assert(1 - health_tracker_record(t2, "svc2", 1, 2), "svc2 pass no restart");
}

