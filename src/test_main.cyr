# =========================================================================
# dm-verity tests
# =========================================================================

fn test_dm_verity() {
    println("--- dm-verity ---");

    # Valid hash (64 hex chars)
    var hash = str_from("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa");
    var cmds = verify_rootfs_integrity(str_from("/dev/sda1"), str_from("/dev/sda2"), hash);
    assert(cmds != 0, "valid verity succeeds");
    assert_eq(vec_len(cmds), 2, "verity 2 commands");

    # Empty params
    var r1 = verify_rootfs_integrity(str_from(""), str_from("/dev/sda2"), hash);
    assert_eq(r1, 0, "empty root fails");
    var r2 = verify_rootfs_integrity(str_from("/dev/sda1"), str_from(""), hash);
    assert_eq(r2, 0, "empty hash dev fails");
    var r3 = verify_rootfs_integrity(str_from("/dev/sda1"), str_from("/dev/sda2"), str_from(""));
    assert_eq(r3, 0, "empty hash fails");

    # Bad hash length
    var r4 = verify_rootfs_integrity(str_from("/dev/sda1"), str_from("/dev/sda2"), str_from("abcdef"));
    assert_eq(r4, 0, "short hash fails");

    # Bad device path
    var r5 = verify_rootfs_integrity(str_from("/tmp/sda1"), str_from("/dev/sda2"), hash);
    assert_eq(r5, 0, "non-dev path fails");
}

