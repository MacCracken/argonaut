[package]
name = "argonaut-helpers"
version = "1.6.3"
description = "Statically-linked helpers bundled in the qemu PID-1 harness initramfs"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.0.1"

[build]
entry = "l3-helper.cyr"
output = "l3-helper"

# Minimal stdlib — these helpers do syscalls directly; no Str,
# vec, alloc, etc. needed. Keeps the binary tiny.
[deps]
stdlib = ["syscalls"]
