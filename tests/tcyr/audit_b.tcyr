# audit_b.tcyr - Audit extras (chain linkage, accessors, severity ordering, filters)
# Uses libro 1.0.2 SHA-256 hash-linked chain (replaced FNV-1a shim)

# Core stdlib
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/assert.cyr"
include "lib/json.cyr"
include "lib/freelist.cyr"

# Libro dependencies
include "lib/bigint.cyr"
include "lib/chrono.cyr"
include "lib/sigil.cyr"

# Sakshi stubs for tests
fn sakshi_info(msg, len) { return 0; }
fn sakshi_warn(msg, len) { return 0; }
fn sakshi_error(msg, len) { return 0; }
fn sakshi_debug(msg, len) { return 0; }
fn sakshi_trace(msg, len) { return 0; }
fn sakshi_span_enter(name, len) { return 0; }
fn sakshi_span_exit() { return 0; }
fn sakshi_span_depth() { return 0; }

# Libro core chain modules
include "lib/libro/error.cyr"
include "lib/libro/hasher.cyr"
include "lib/libro/entry.cyr"
include "lib/libro/verify.cyr"
include "lib/libro/query.cyr"
include "lib/libro/retention.cyr"
include "lib/libro/chain.cyr"

# Argonaut audit bridge
include "src/audit.cyr"

fn main() {
    alloc_init();
    test_group("audit-extras");

    var log6 = audit_log_new();
    for (var i = 0; i < 10; i = i + 1) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "svc-");
        str_builder_add_int(sb, i);
        audit_log_record(log6, str_data(str_builder_build(sb)), EVT_STARTING);
    }

    var entries = audit_log_entries(log6);
    var e0 = vec_get(entries, 0);

    # Genesis entry prev_hash is empty string (libro convention)
    var ph0 = audit_entry_prev_hash(e0);
    assert_eq(str_len(ph0), 0, "gen ph empty");

    # Chain linkage: e1.prev_hash == e0.hash
    var e1 = vec_get(entries, 1);
    assert(str_eq(audit_entry_prev_hash(e1), audit_entry_hash(e0)), "lnk e1");

    # Entry accessors
    assert_eq(audit_entry_severity(e0), SEV_INFO, "ea sev");
    assert(str_eq(audit_entry_source(e0), str_from("argonaut")), "ea src");
    assert(str_eq(audit_entry_action(e0), str_from("Starting")), "ea act");

    # Timestamp is RFC 3339 Str (20 chars: "YYYY-MM-DDTHH:MM:SSZ")
    var ts = audit_entry_timestamp(e0);
    assert_eq(str_len(ts), 20, "ea ts len");

    # Hash is 64-char hex SHA-256 Str
    var hash = audit_entry_hash(e0);
    assert_eq(str_len(hash), 64, "ea hash len");

    # Severity ordering
    assert(SEV_DEBUG < SEV_INFO, "o d<i");
    assert(SEV_INFO < SEV_WARNING, "o i<w");
    assert(SEV_WARNING < SEV_ERROR, "o w<e");
    assert(SEV_ERROR < SEV_CRITICAL, "o e<c");
    assert(SEV_CRITICAL < SEV_SECURITY, "o c<s");

    # Min severity filter
    var log7 = audit_log_new();
    audit_log_record(log7, "a", EVT_STARTING);
    audit_log_record(log7, "b", EVT_STOPPING);
    audit_log_record(log7, "c", EVT_TIMEOUT_KILLED);
    assert_eq(vec_len(audit_log_by_min_severity(log7, SEV_WARNING)), 2, "ms 2w");
    assert_eq(vec_len(audit_log_by_min_severity(log7, SEV_ERROR)), 1, "ms 1e");

    # Severity string (libro uses capitalized names)
    assert(streq(severity_as_str(SEV_DEBUG), "Debug"), "ss dbg");
    assert(streq(severity_as_str(SEV_INFO), "Info"), "ss inf");
    assert(streq(severity_as_str(SEV_WARNING), "Warning"), "ss wrn");
    assert(streq(severity_as_str(SEV_ERROR), "Error"), "ss err");

    # Event type string
    assert(streq(event_type_str(EVT_STARTING), "Starting"), "es st");
    assert(streq(event_type_str(EVT_TIMEOUT_KILLED), "TimeoutKilled"), "es tk");

    # SHA-256 chain verification (10 entries, all valid)
    assert_eq(audit_log_verify(log6), 1, "sha chain ok");

    # Individual entry verification via libro
    assert_eq(entry_verify(e0), 1, "e0 verify");
    assert_eq(entry_verify(e1), 1, "e1 verify");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
