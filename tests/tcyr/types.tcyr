# types.tcyr - Tests for types, boot sequences, default services, config
include "tests/test_header.cyr"
fn main() {
    alloc_init();

test_group("types-boot-services");

# --- BootMode ---
assert(streq(boot_mode_str(BOOT_SERVER), "server"), "mode server");
assert(streq(boot_mode_str(BOOT_DESKTOP), "desktop"), "mode desktop");
assert(streq(boot_mode_str(BOOT_MINIMAL), "minimal"), "mode minimal");
assert(streq(boot_mode_str(BOOT_EDGE), "edge"), "mode edge");
assert(streq(boot_mode_str(BOOT_RECOVERY), "recovery"), "mode recovery");

# --- BootStage ordering ---
assert(STAGE_MOUNT_FS < STAGE_DEVICE_MGR, "stage mount<device");
assert(STAGE_DEVICE_MGR < STAGE_VERIFY_ROOTFS, "stage dev<verify");
assert(STAGE_SECURITY < STAGE_DATABASE, "stage sec<db");
assert(STAGE_DATABASE < STAGE_AGENT_RUNTIME, "stage db<agent");
assert(STAGE_LLM_GATEWAY < STAGE_MODEL_SERVICES, "stage llm<model");
assert(STAGE_COMPOSITOR < STAGE_SHELL, "stage comp<shell");
assert(STAGE_SHELL < STAGE_BOOT_COMPLETE, "stage shell<done");

# --- BootStage display ---
assert(streq(boot_stage_str(STAGE_MOUNT_FS), "mount-filesystems"), "stage str mount");
assert(streq(boot_stage_str(STAGE_BOOT_COMPLETE), "boot-complete"), "stage str done");
assert(streq(boot_stage_str(STAGE_DATABASE), "start-database-services"), "stage str db");

# --- BootStepStatus ---
assert(streq(step_status_str(STEP_PENDING), "pending"), "step pending");
assert(streq(step_status_str(STEP_RUNNING), "running"), "step running");
assert(streq(step_status_str(STEP_COMPLETE), "complete"), "step complete");
assert(streq(step_status_str(STEP_FAILED), "failed"), "step failed");
assert(streq(step_status_str(STEP_SKIPPED), "skipped"), "step skipped");

# --- RestartPolicy ---
assert(streq(restart_policy_str(RESTART_ALWAYS), "always"), "pol always");
assert(streq(restart_policy_str(RESTART_ON_FAILURE), "on-failure"), "pol onfail");
assert(streq(restart_policy_str(RESTART_NEVER), "never"), "pol never");

# --- ServiceType ---
assert(streq(service_type_str(SVC_SIMPLE), "simple"), "type simple");
assert(streq(service_type_str(SVC_FORKING), "forking"), "type forking");
assert(streq(service_type_str(SVC_ONESHOT), "oneshot"), "type oneshot");

# --- ShutdownType ---
assert(streq(shutdown_type_str(SHUTDOWN_POWEROFF), "poweroff"), "sd poweroff");
assert(streq(shutdown_type_str(SHUTDOWN_REBOOT), "reboot"), "sd reboot");
assert(streq(shutdown_type_str(SHUTDOWN_HALT), "halt"), "sd halt");
assert(streq(shutdown_type_str(SHUTDOWN_KEXEC), "kexec"), "sd kexec");

# --- Boot sequence counts ---
assert_eq(vec_len(build_boot_sequence(BOOT_MINIMAL)), 6, "min 6 steps");
assert_eq(vec_len(build_boot_sequence(BOOT_SERVER)), 9, "srv 9 steps");
assert_eq(vec_len(build_boot_sequence(BOOT_DESKTOP)), 11, "dsk 11 steps");
assert_eq(vec_len(build_boot_sequence(BOOT_EDGE)), 6, "edge 6 steps");
assert_eq(vec_len(build_boot_sequence(BOOT_RECOVERY)), 5, "rec 5 steps");

# --- Stage presence ---
var min_s = build_boot_sequence(BOOT_MINIMAL);
assert(steps_has_stage(min_s, STAGE_AGENT_RUNTIME), "min has agent");
assert(steps_has_stage(min_s, STAGE_BOOT_COMPLETE), "min has done");
assert(1 - steps_has_stage(min_s, STAGE_COMPOSITOR), "min no comp");
assert(1 - steps_has_stage(min_s, STAGE_LLM_GATEWAY), "min no llm");
assert(1 - steps_has_stage(min_s, STAGE_DATABASE), "min no db");

var srv_s = build_boot_sequence(BOOT_SERVER);
assert(steps_has_stage(srv_s, STAGE_DATABASE), "srv has db");
assert(steps_has_stage(srv_s, STAGE_LLM_GATEWAY), "srv has llm");
assert(1 - steps_has_stage(srv_s, STAGE_COMPOSITOR), "srv no comp");

var dsk_s = build_boot_sequence(BOOT_DESKTOP);
assert(steps_has_stage(dsk_s, STAGE_COMPOSITOR), "dsk has comp");
assert(steps_has_stage(dsk_s, STAGE_SHELL), "dsk has shell");

var edge_s = build_boot_sequence(BOOT_EDGE);
assert(1 - steps_has_stage(edge_s, STAGE_DATABASE), "edge no db");
assert(1 - steps_has_stage(edge_s, STAGE_COMPOSITOR), "edge no comp");

# --- Default services ---
var min_v = default_services(BOOT_MINIMAL);
assert_eq(vec_len(min_v), 1, "min 1 svc");
assert(svcs_has_name(min_v, "daimon"), "min daimon");

var srv_v = default_services(BOOT_SERVER);
assert_eq(vec_len(srv_v), 5, "srv 5 svcs");
assert(svcs_has_name(srv_v, "postgres"), "srv postgres");
assert(svcs_has_name(srv_v, "redis"), "srv redis");
assert(svcs_has_name(srv_v, "ifran"), "srv ifran");

var dsk_v = default_services(BOOT_DESKTOP);
assert_eq(vec_len(dsk_v), 7, "dsk 7 svcs");
assert(svcs_has_name(dsk_v, "aethersafha"), "dsk comp");
assert(svcs_has_name(dsk_v, "agnoshi"), "dsk shell");

var edge_v = default_services(BOOT_EDGE);
assert_eq(vec_len(edge_v), 1, "edge 1 svc");
assert(1 - svcs_has_name(edge_v, "postgres"), "edge no pg");

assert_eq(vec_len(default_services(BOOT_RECOVERY)), 0, "rec 0 svcs");

# --- Config defaults ---
var cfg = argonaut_config_default();
assert_eq(config_boot_mode(cfg), BOOT_DESKTOP, "cfg mode dsk");
assert_eq(config_boot_timeout(cfg), 30000, "cfg boot timeout");
assert_eq(config_shutdown_timeout(cfg), 10000, "cfg sd timeout");
assert_eq(config_log_console(cfg), 1, "cfg log console");
assert_eq(config_verify_boot(cfg), 1, "cfg verify boot");

# --- Edge boot config ---
var ec = edge_config_default();
assert_eq(load64(ec), 1, "ec readonly");
assert_eq(load64(ec + 8), 1, "ec luks");
assert_eq(load64(ec + 24), 3000, "ec max boot");

# --- Restart config ---
var rc = restart_config_default();
assert_eq(backoff_delay(rc, 0), 1000, "bo 0");
assert_eq(backoff_delay(rc, 1), 2000, "bo 1");
assert_eq(backoff_delay(rc, 2), 4000, "bo 2");
assert_eq(backoff_delay(rc, 3), 8000, "bo 3");
assert_eq(backoff_delay(rc, 4), 16000, "bo 4");
assert_eq(backoff_delay(rc, 5), 30000, "bo 5 cap");
assert(1 - restart_limit_exceeded(rc, 4), "lim ok 4");
assert(restart_limit_exceeded(rc, 5), "lim hit 5");

# --- Runlevel ---
assert_eq(runlevel_to_boot_mode(RL_CONSOLE), BOOT_SERVER, "rl c->srv");
assert_eq(runlevel_to_boot_mode(RL_GRAPHICAL), BOOT_DESKTOP, "rl g->dsk");
assert_eq(runlevel_to_boot_mode(RL_EDGE), BOOT_EDGE, "rl e->edge");
assert_eq(boot_mode_to_runlevel(BOOT_SERVER), RL_CONSOLE, "srv->c");
assert_eq(boot_mode_to_runlevel(BOOT_DESKTOP), RL_GRAPHICAL, "dsk->g");
assert_eq(runlevel_level(RL_EMERGENCY), 0, "rl lvl 0");
assert_eq(runlevel_level(RL_CONSOLE), 3, "rl lvl 3");
assert_eq(runlevel_level(RL_GRAPHICAL), 5, "rl lvl 5");
assert_eq(runlevel_level(RL_EDGE), 8, "rl lvl 8");
assert(streq(runlevel_str(RL_EMERGENCY), "emergency"), "rl str em");
assert(streq(runlevel_str(RL_CONSOLE), "console"), "rl str con");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
