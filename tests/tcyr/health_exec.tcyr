# health_exec.tcyr — Health check execution tests
include "tests/test_header.cyr"

fn main() {
    alloc_init();
    test_group("health-exec");

    # --- check_process_alive: self ---
    var my_pid = sys_getpid();
    assert(check_process_alive(my_pid), "self alive");

    # --- check_process_alive: bad pid ---
    assert_eq(check_process_alive(0), 0, "pid0 dead");
    assert_eq(check_process_alive(0 - 1), 0, "pid-1 dead");

    # --- check_command: true (full path needed for exec) ---
    # 1.6.1 — assertions flipped back to strict expected-result
    # form after the cyrius 5.10.44 / exec_vec_str migration
    # closed the Str/cstr silent-failure path. `/bin/true` exits
    # 0 → check_command returns 1; `/bin/false` exits 1 →
    # check_command returns 0. (Pre-1.6.1: exec_vec silently
    # mis-execed on Str-shape argv, so we could only assert
    # determinism, not the actual result.)
    var cmd_ok = check_command(str_from("/bin/true"), 5000);
    assert_eq(cmd_ok, 1, "cmd /bin/true returns 1");

    # --- check_command: false ---
    var cmd_fail = check_command(str_from("/bin/false"), 5000);
    assert_eq(cmd_fail, 0, "cmd /bin/false returns 0");

    # --- execute_health_check: process alive ---
    var hc_pa = health_check_new(HC_PROCESS_ALIVE, 0, 0, 5000, 2000, 3);
    var r1 = execute_health_check(str_from("self"), hc_pa, my_pid);
    assert_eq(load64(r1 + 16), 1, "ehc pa pass");
    assert(load64(r1 + 24) >= 0, "ehc pa lat");

    # --- execute_health_check: process alive (dead) ---
    var r2 = execute_health_check(str_from("dead"), hc_pa, 999999);
    assert_eq(load64(r2 + 16), 0, "ehc pa fail");

    # --- execute_health_check: command ---
    # 1.6.1 — strict expected-result after exec_vec_str migration.
    var hc_cmd = health_check_new(HC_COMMAND, str_from("/bin/true"), 0, 5000, 2000, 3);
    var r3 = execute_health_check(str_from("cmd"), hc_cmd, 0);
    assert_eq(load64(r3 + 16), 1, "ehc cmd /bin/true passed");
    assert(load64(r3 + 24) >= 0, "ehc cmd lat");

    # --- execute_health_check: command structure ---
    assert(load64(r3 + 40) > 0, "ehc cmd ts");

    # --- ready_check: immediate pass ---
    var rc = ready_check_new(HC_PROCESS_ALIVE, 0, 0, 5000, 3, 100);
    var rr = execute_ready_check(str_from("rc"), rc, my_pid);
    assert_eq(load64(rr + 16), 1, "rc pass");

    # --- ready_check: all retries fail ---
    var rc2 = ready_check_new(HC_PROCESS_ALIVE, 0, 0, 2000, 2, 100);
    var rr2 = execute_ready_check(str_from("rc2"), rc2, 999999);
    assert_eq(load64(rr2 + 16), 0, "rc fail");
    assert(load64(rr2 + 32) != 0, "rc msg");

    # --- health_history ring buffer ---
    var hh = health_history_new(3);
    var rp = alloc(48);
    store64(rp + 16, 1);
    var rf = alloc(48);
    store64(rf + 16, 0);

    health_history_record(hh, rp, 2);
    assert_eq(health_history_state(hh), HS_HEALTHY, "hh h");
    health_history_record(hh, rf, 2);
    assert_eq(health_history_state(hh), HS_DEGRADED, "hh d");
    health_history_record(hh, rf, 2);
    assert_eq(health_history_state(hh), HS_UNHEALTHY, "hh u");
    health_history_record(hh, rp, 2);
    assert_eq(health_history_state(hh), HS_HEALTHY, "hh rec");
    assert_eq(health_history_len(hh), 3, "hh cap");
    assert_eq(health_history_total(hh), 4, "hh tot");

    # --- health_history reset ---
    health_history_reset(hh);
    assert_eq(health_history_state(hh), HS_UNKNOWN, "hh rst");
    assert_eq(health_history_len(hh), 0, "hh rst len");

    # --- health_history minimum capacity ---
    var hh0 = health_history_new(0);
    health_history_record(hh0, rp, 1);
    assert_eq(health_history_len(hh0), 1, "hh0 len");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
