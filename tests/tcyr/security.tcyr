# security.tcyr — Security tests
include "tests/test_header.cyr"

fn main() {
    alloc_init();
    test_group("security");

    # --- landlock_description ---
    var rules = vec_new();
    var r1 = alloc(16);
    store64(r1, str_from("/usr"));
    store64(r1 + 8, LL_READ_ONLY);
    vec_push(rules, r1);
    var r2 = alloc(16);
    store64(r2, str_from("/var/lib"));
    store64(r2 + 8, LL_READ_WRITE);
    vec_push(rules, r2);

    var desc = landlock_description(rules);
    assert(str_contains(desc, str_from("2 filesystem")), "ll cnt");
    assert(str_contains(desc, str_from("/usr")), "ll usr");
    assert(str_contains(desc, str_from("ro")), "ll ro");
    assert(str_contains(desc, str_from("/var/lib")), "ll var");
    assert(str_contains(desc, str_from("rw")), "ll rw");

    # --- landlock_description: empty ---
    var desc2 = landlock_description(vec_new());
    assert(str_contains(desc2, str_from("0 filesystem")), "ll empty");

    # --- capability_setpriv_cmd ---
    var caps = vec_new();
    vec_push(caps, CAP_NET_BIND_SERVICE);
    vec_push(caps, CAP_SYS_ADMIN);
    var cmd = capability_setpriv_cmd(caps, str_from("/usr/bin/myapp"), vec_new());
    assert(streq(str_data(safe_cmd_binary(cmd)), "setpriv"), "cap bin");
    var disp = safe_cmd_display(cmd);
    assert(str_contains(disp, str_from("--no-new-privs")), "cap nnp");
    assert(str_contains(disp, str_from("bounding")), "cap bound");
    assert(str_contains(disp, str_from("cap_net_bind_service")), "cap net");
    assert(str_contains(disp, str_from("cap_sys_admin")), "cap sys");
    assert(str_contains(disp, str_from("/usr/bin/myapp")), "cap app");

    # --- capability_setpriv_cmd: with args ---
    var args = vec_new();
    vec_push(args, str_from("--port"));
    vec_push(args, str_from("8080"));
    var cmd2 = capability_setpriv_cmd(vec_new(), str_from("/bin/srv"), args);
    var disp2 = safe_cmd_display(cmd2);
    assert(str_contains(disp2, str_from("--port")), "cap arg1");
    assert(str_contains(disp2, str_from("8080")), "cap arg2");

    # --- capability_setpriv_cmd: no caps to drop ---
    var cmd3 = capability_setpriv_cmd(vec_new(), str_from("/bin/x"), vec_new());
    var disp3 = safe_cmd_display(cmd3);
    assert(str_contains(disp3, str_from("--no-new-privs")), "cap nnp2");

    # --- seccomp_description: basic ---
    var sdesc = seccomp_description(0, 0, 0);
    assert(str_contains(sdesc, str_from("basic")), "sec basic");
    assert(str_contains(sdesc, str_from("20")), "sec 20");

    # --- seccomp_description: custom ---
    var sdesc2 = seccomp_description(1, 15, 3);
    assert(str_contains(sdesc2, str_from("custom")), "sec custom");
    assert(str_contains(sdesc2, str_from("15")), "sec allow");
    assert(str_contains(sdesc2, str_from("3")), "sec deny");

    # --- constant_time_eq ---
    assert(constant_time_eq("abc", 3, "abc", 3), "cte eq");
    assert_eq(constant_time_eq("abc", 3, "abd", 3), 0, "cte ne");
    assert_eq(constant_time_eq("ab", 2, "abc", 3), 0, "cte len");

    # --- verify_emergency_auth: no auth required ---
    var esc = emergency_shell_default();
    assert(verify_emergency_auth(esc, str_from("anything")), "auth no");

    # --- password_hash: deterministic ---
    var h1 = password_hash("test", 4);
    var h2 = password_hash("test", 4);
    assert_eq(h1, h2, "hash det");
    var h3 = password_hash("other", 5);
    assert(h1 != h3, "hash diff");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
