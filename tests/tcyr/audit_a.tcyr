# audit_a.tcyr - Core audit logging tests (record, severity, query, verify)
# Uses libro 1.0.2 SHA-256 hash-linked chain (replaced FNV-1a shim)

# Core stdlib
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/assert.cyr"
include "lib/bayan.cyr"
include "lib/freelist.cyr"

# Libro dependencies
include "lib/chrono.cyr"
include "lib/thread_local.cyr"
include "lib/sigil.cyr"

# Sakshi stubs for tests
fn sakshi_info(msg, len) { return 0; }
fn sakshi_warn(msg, len) { return 0; }
fn sakshi_error(msg, len) { return 0; }
fn sakshi_debug(msg, len) { return 0; }
fn sakshi_trace(msg, len) { return 0; }
fn sakshi_span_enter(name, len) { return 0; }
fn sakshi_span_exit() { return 0; }
fn sakshi_span_depth() { return 0; }

# Libro core chain modules
include "lib/libro.cyr"

# Argonaut audit bridge
include "src/audit.cyr"

fn main() {
    alloc_init();
    test_group("audit-core");

    var log = argonaut_audit_log_new();
    audit_log_record(log, "daimon", EVT_STARTING);
    assert_eq(audit_log_len(log), 1, "rec 1");
    assert_eq(audit_log_is_empty(log) == 0, 1, "!mt");

    var log2 = argonaut_audit_log_new();
    audit_log_record(log2, "daimon", EVT_STARTING);
    audit_log_record(log2, "daimon", EVT_STARTED);
    audit_log_record(log2, "daimon", EVT_HEALTH_PASSED);
    assert_eq(audit_log_len(log2), 3, "mul 3");
    assert_eq(audit_log_verify(log2), 1, "chain ok");

    assert_eq(audit_event_severity(EVT_STARTING), SEV_INFO, "s:st");
    assert_eq(audit_event_severity(EVT_STARTED), SEV_INFO, "s:sd");
    assert_eq(audit_event_severity(EVT_HEALTH_PASSED), SEV_INFO, "s:hp");
    assert_eq(audit_event_severity(EVT_READY_PASSED), SEV_INFO, "s:rp");
    assert_eq(audit_event_severity(EVT_DEP_MET), SEV_INFO, "s:dm");
    assert_eq(audit_event_severity(EVT_STOPPED_OK), SEV_INFO, "s:s0");
    assert_eq(audit_event_severity(EVT_ENABLED), SEV_INFO, "s:en");
    assert_eq(audit_event_severity(EVT_DISABLED), SEV_INFO, "s:di");

    assert_eq(audit_event_severity(EVT_STOPPING), SEV_WARNING, "s:sp");
    assert_eq(audit_event_severity(EVT_RESTARTING), SEV_WARNING, "s:rs");
    assert_eq(audit_event_severity(EVT_DEP_WAITING), SEV_WARNING, "s:dw");
    assert_eq(audit_event_severity(EVT_HEALTH_FAILED), SEV_WARNING, "s:hf");
    assert_eq(audit_event_severity(EVT_READY_FAILED), SEV_WARNING, "s:rf");

    assert_eq(audit_event_severity(EVT_TIMEOUT_KILLED), SEV_ERROR, "s:tk");
    assert_eq(audit_event_severity(EVT_CRASH_DETECTED), SEV_ERROR, "s:cr");
    assert_eq(audit_event_severity(EVT_STOPPED_FAIL), SEV_ERROR, "s:sf");

    var log3 = argonaut_audit_log_new();
    audit_log_record(log3, "daimon", EVT_STARTING);
    audit_log_record(log3, "redis", EVT_STARTING);
    var by_src = audit_log_by_source(log3, "argonaut");
    assert_eq(vec_len(by_src), 2, "src 2");

    var log4 = argonaut_audit_log_new();
    audit_log_record(log4, "daimon", EVT_STARTING);
    audit_log_record(log4, "daimon", EVT_TIMEOUT_KILLED);
    assert_eq(vec_len(audit_log_by_severity(log4, SEV_ERROR)), 1, "sev 1e");
    assert_eq(vec_len(audit_log_by_severity(log4, SEV_INFO)), 1, "sev 1i");

    var log5 = argonaut_audit_log_new();
    audit_log_record(log5, "daimon", EVT_STARTING);
    audit_log_record(log5, "daimon", EVT_TIMEOUT_KILLED);
    assert_eq(vec_len(audit_log_query(log5, "argonaut", SEV_ERROR)), 1, "q 1e");

    var log6 = argonaut_audit_log_new();
    for (var i = 0; i < 10; i = i + 1) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "svc-");
        str_builder_add_int(sb, i);
        audit_log_record(log6, str_data(str_builder_build(sb)), EVT_STARTING);
    }
    assert_eq(audit_log_len(log6), 10, "int l10");
    assert_eq(audit_log_verify(log6), 1, "int ok");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
