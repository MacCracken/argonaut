# process.tcyr — Process management tests
include "tests/test_header.cyr"

fn main() {
    alloc_init();
    test_group("process-mgmt");

    # --- proc_table basic ops ---
    proc_table_init();
    assert_eq(proc_table_count(), 0, "pt empty");

    proc_table_insert(str_from("alpha"), 100);
    proc_table_insert(str_from("beta"), 200);
    assert_eq(proc_table_count(), 2, "pt cnt 2");
    assert(proc_table_has(str_from("alpha")), "pt has a");
    assert_eq(proc_table_pid(str_from("alpha")), 100, "pt pid a");
    assert_eq(proc_table_pid(str_from("beta")), 200, "pt pid b");

    proc_table_remove(str_from("alpha"));
    assert_eq(proc_table_count(), 1, "pt rm a");
    assert_eq(proc_table_has(str_from("alpha")), 0, "pt no a");
    assert(proc_table_has(str_from("beta")), "pt still b");

    # --- proc_table keys ---
    proc_table_init();
    proc_table_insert(str_from("x"), 10);
    proc_table_insert(str_from("y"), 20);
    proc_table_insert(str_from("z"), 30);
    var keys = proc_table_keys();
    assert_eq(vec_len(keys), 3, "pt keys 3");

    # --- proc_table reinit ---
    proc_table_init();
    assert_eq(proc_table_count(), 0, "pt reinit");

    # --- process_alive on non-existent PID ---
    assert_eq(process_alive(0), 0, "pid0 dead");
    assert_eq(process_alive(0 - 1), 0, "pid-1 dead");

    # --- safe_cmd execution ---
    # Note: exec_vec/exec_env in test env returns 127 (exec fails)
    # Test that run_safe_cmd returns a result and doesn't crash
    var cmd = safe_cmd_new(str_from("/bin/true"));
    var code = run_safe_cmd(cmd);
    # exec_vec returns 127 in test env — test determinism
    assert(code >= 0 || code == (0 - 1), "cmd ret");

    var cmd2 = safe_cmd_new(str_from("/nonexistent"));
    var code2 = run_safe_cmd(cmd2);
    assert(code2 != 0, "bad cmd fail");

    # --- safe_cmd_sequence: stops on first failure ---
    var seq = vec_new();
    vec_push(seq, safe_cmd_new(str_from("/nonexistent")));
    vec_push(seq, safe_cmd_new(str_from("/bin/true")));
    assert(run_safe_cmd_sequence(seq) != 0, "seq fail");

    # --- safe_cmd_sequence: empty succeeds ---
    assert_eq(run_safe_cmd_sequence(vec_new()), 0, "seq empty");

    # --- safe_cmd_display ---
    var dc = safe_cmd_new(str_from("prlimit"));
    safe_cmd_add_arg(dc, str_from("--pid"));
    safe_cmd_add_arg(dc, str_from("42"));
    var disp = safe_cmd_display(dc);
    assert(str_contains(disp, str_from("prlimit")), "disp bin");
    assert(str_contains(disp, str_from("--pid")), "disp arg1");
    assert(str_contains(disp, str_from("42")), "disp arg2");

    # --- to_prlimit_commands ---
    var rl = alloc(sizeof(ResourceLimits));
    store64(rl, 1024);       # nofile
    store64(rl + 8, 0);      # address_space (not set)
    store64(rl + 16, 512);   # nproc
    store64(rl + 24, 0);     # core disabled
    var cmds = to_prlimit_commands(rl, 999);
    assert_eq(vec_len(cmds), 3, "prlimit 3");
    var c0 = safe_cmd_display(vec_get(cmds, 0));
    assert(str_contains(c0, str_from("nofile")), "prl nofile");
    assert(str_contains(c0, str_from("999")), "prl pid");

    # --- to_prlimit_commands: empty ---
    var rl2 = resource_limits_empty();
    var cmds2 = to_prlimit_commands(rl2, 1);
    assert_eq(vec_len(cmds2), 0, "prl empty");

    # --- to_prlimit_commands: secure (core=0) ---
    var rl3 = resource_limits_secure();
    var cmds3 = to_prlimit_commands(rl3, 1);
    assert_eq(vec_len(cmds3), 1, "prl secure");
    var c3 = safe_cmd_display(vec_get(cmds3, 0));
    assert(str_contains(c3, str_from("core=0")), "prl core0");

    # --- fork_exec_service: spawns child ---
    var sd = svc_def_new(str_from("test-sleep"), str_from("test"), str_from("/bin/sleep"));
    vec_push(svc_def_args(sd), str_from("0"));
    var pid = fork_exec_service(sd);
    assert(pid > 0, "fork pid>0");
    # Wait for it
    var wbuf[8];
    sys_waitpid(pid, &wbuf, 0);

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
