# api_b.tcyr - Process table, socket activation tests
include "tests/test_header.cyr"

fn main() {
    alloc_init();
    test_group("proc-socket");

    # --- Process table basic ops ---
    proc_table_init();
    assert_eq(proc_table_count(), 0, "pt mt");
    proc_table_insert(str_from("svc-a"), 12345);
    assert_eq(proc_table_count(), 1, "pt 1");
    assert(proc_table_has(str_from("svc-a")), "pt has");
    assert_eq(proc_table_pid(str_from("svc-a")), 12345, "pt pid");
    proc_table_remove(str_from("svc-a"));
    assert_eq(proc_table_count(), 0, "pt rm");

    # --- Process table: multi-entry + keys ---
    proc_table_init();
    proc_table_insert(str_from("alpha"), 100);
    proc_table_insert(str_from("beta"), 200);
    proc_table_insert(str_from("gamma"), 300);
    assert_eq(proc_table_count(), 3, "pt 3");
    assert(proc_table_has(str_from("beta")), "pt b");
    assert_eq(proc_table_pid(str_from("gamma")), 300, "pt g");
    assert_eq(proc_table_has(str_from("nonexistent")), 0, "pt !x");
    assert_eq(proc_table_pid(str_from("nonexistent")), 0, "pt x0");

    var keys = proc_table_keys();
    assert_eq(vec_len(keys), 3, "pt k3");

    proc_table_remove(str_from("beta"));
    assert_eq(proc_table_count(), 2, "pt 2");
    assert_eq(proc_table_has(str_from("beta")), 0, "pt !b");
    assert(proc_table_has(str_from("alpha")), "pt a");
    assert(proc_table_has(str_from("gamma")), "pt g");

    proc_table_init();
    assert_eq(proc_table_count(), 0, "pt ri");

    # --- Notify: socket env ---
    var nenv = socket_env_listen_fds(3, 42);
    assert_eq(vec_len(nenv), 4, "ne 4");

    return assert_summary();
}
var r = main();
syscall(SYS_EXIT, r);
