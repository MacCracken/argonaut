# audit_findings.tcyr — regression tests for the 1.4.0 P(-1) audit
# (docs/audit/2026-04-26-audit.md). Each `test_group` block targets one
# finding; comments cite the severity tag.

include "tests/test_header.cyr"

fn main() {
    alloc_init();

    # =====================================================================
    # is_hex64 — defensive validation of dm-verity root hashes (LOW-2)
    # =====================================================================
    test_group("audit-low2-is_hex64");

    var h_lower = str_from("0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef");
    var h_upper = str_from("0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF0123456789ABCDEF");
    var h_mixed = str_from("0123456789aBcDeF0123456789AbCdEf0123456789abcdef0123456789ABCDEF");
    assert_eq(is_hex64(h_lower), 1, "is_hex64: 64 lowercase hex");
    assert_eq(is_hex64(h_upper), 1, "is_hex64: 64 uppercase hex");
    assert_eq(is_hex64(h_mixed), 1, "is_hex64: mixed-case hex");

    var h_short = str_from("deadbeef");
    var h_long = str_from("0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef00");
    assert_eq(is_hex64(h_short), 0, "is_hex64: rejects short");
    assert_eq(is_hex64(h_long),  0, "is_hex64: rejects long");

    var h_dash = str_from("0123456789abcdef0123456789abcdef0123456789abcdef0123456789abc--ef");
    var h_inj  = str_from("--injected-arg-deadbeef-deadbeef-deadbeef-deadbeef-deadbeef-dead");
    assert_eq(is_hex64(h_dash), 0, "is_hex64: rejects '-' in hash");
    assert_eq(is_hex64(h_inj),  0, "is_hex64: rejects argv-injection-shaped");

    var h_space = str_from("0123456789abcdef 123456789abcdef0123456789abcdef0123456789abcdef");
    assert_eq(is_hex64(h_space), 0, "is_hex64: rejects whitespace");

    # =====================================================================
    # validate_mapper_name — LUKS mapped-device alias (LOW-1)
    # =====================================================================
    test_group("audit-low1-mapper_name");

    assert_eq(validate_mapper_name(str_from("agnos-data")),    1, "mapper: agnos-data");
    assert_eq(validate_mapper_name(str_from("verified_root")), 1, "mapper: verified_root");
    assert_eq(validate_mapper_name(str_from("a")),             1, "mapper: 1-char ok");

    assert_eq(validate_mapper_name(str_from("")),               0, "mapper: rejects empty");
    assert_eq(validate_mapper_name(str_from("../../../etc")),   0, "mapper: rejects ../");
    assert_eq(validate_mapper_name(str_from("foo/bar")),        0, "mapper: rejects slash");
    assert_eq(validate_mapper_name(str_from("foo bar")),        0, "mapper: rejects space");
    assert_eq(validate_mapper_name(str_from("foo;rm")),         0, "mapper: rejects ';'");
    assert_eq(validate_mapper_name(str_from("name\nwith\nnl")), 0, "mapper: rejects newline");

    var long_name = str_from("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa");   # 33 chars
    assert_eq(validate_mapper_name(long_name), 0, "mapper: rejects > 32 chars");

    # =====================================================================
    # HIGH-1 — host resolver replaces loopback-only gate (closed 1.5.2)
    # =====================================================================
    # The 1.4.0 fix (`is_localhost_target` gate) preserved the safety
    # property at the cost of feature surface; 1.5.2 swaps in a real
    # IPv4 dotted-quad parser + /etc/hosts scan
    # (`src/resolver.cyr`), so external health checks work as
    # configured while keeping the no-silent-localhost-fallback
    # invariant. `is_localhost_target` is retained for callers that
    # need the predicate; it's no longer the only path through.
    test_group("audit-high1-resolver");

    # --- parse_ipv4 — accepts well-formed dotted quads ---
    assert(parse_ipv4(str_from("127.0.0.1"))         >= 0, "parse_ipv4: 127.0.0.1");
    assert(parse_ipv4(str_from("0.0.0.0"))           >= 0, "parse_ipv4: 0.0.0.0");
    assert(parse_ipv4(str_from("255.255.255.255"))   >= 0, "parse_ipv4: broadcast");
    assert(parse_ipv4(str_from("10.0.0.1"))          >= 0, "parse_ipv4: 10/8");
    assert(parse_ipv4(str_from("192.168.1.1"))       >= 0, "parse_ipv4: 192.168/16");

    # Packing is BE: 127.0.0.1 → (127<<24)|0|0|1 = 0x7f000001.
    assert_eq(parse_ipv4(str_from("127.0.0.1")),         2130706433, "parse_ipv4: 127.0.0.1 packs to 0x7f000001");
    assert_eq(parse_ipv4(str_from("0.0.0.0")),                    0, "parse_ipv4: 0.0.0.0 packs to 0");
    assert_eq(parse_ipv4(str_from("10.0.0.1")),          167772161, "parse_ipv4: 10.0.0.1 packs to 0x0a000001");

    # --- parse_ipv4 — rejects malformed inputs ---
    assert_eq(parse_ipv4(str_from("")),                  0 - 1, "parse_ipv4: rejects empty");
    assert_eq(parse_ipv4(str_from("127")),               0 - 1, "parse_ipv4: rejects single octet");
    assert_eq(parse_ipv4(str_from("127.0.0")),           0 - 1, "parse_ipv4: rejects 3 octets");
    assert_eq(parse_ipv4(str_from("127.0.0.1.5")),       0 - 1, "parse_ipv4: rejects 5 octets");
    assert_eq(parse_ipv4(str_from("256.0.0.1")),         0 - 1, "parse_ipv4: rejects octet > 255");
    assert_eq(parse_ipv4(str_from("999.0.0.1")),         0 - 1, "parse_ipv4: rejects 3-digit overflow");
    assert_eq(parse_ipv4(str_from("127.0.0.")),          0 - 1, "parse_ipv4: rejects trailing dot");
    assert_eq(parse_ipv4(str_from(".127.0.0.1")),        0 - 1, "parse_ipv4: rejects leading dot");
    assert_eq(parse_ipv4(str_from("127..0.1")),          0 - 1, "parse_ipv4: rejects empty octet");
    assert_eq(parse_ipv4(str_from("127.0.0.01")),        0 - 1, "parse_ipv4: rejects leading-zero (CVE-2021-29923)");
    assert_eq(parse_ipv4(str_from("127.0.0.x")),         0 - 1, "parse_ipv4: rejects non-digit");
    assert_eq(parse_ipv4(str_from("localhost")),         0 - 1, "parse_ipv4: rejects hostname");
    assert_eq(parse_ipv4(str_from("::1")),               0 - 1, "parse_ipv4: rejects IPv6");

    # --- resolve_host_ipv4 — full resolution flow ---
    # Dotted quads round-trip through parse_ipv4.
    assert_eq(resolve_host_ipv4(str_from("127.0.0.1")), 2130706433, "resolve: 127.0.0.1 from parser");
    assert_eq(resolve_host_ipv4(str_from("8.8.8.8")),    134744072, "resolve: 8.8.8.8 from parser");

    # /etc/hosts: "localhost" is on every Linux system; resolves
    # to 127.0.0.1 (or whatever the local file pins it to). We
    # don't assert the specific IP — just that resolution succeeds
    # for a name that's always present.
    var localhost_ip = resolve_host_ipv4(str_from("localhost"));
    assert(localhost_ip >= 0, "resolve: localhost present in /etc/hosts");

    # Unresolvable inputs return -1 (not silent-localhost).
    assert_eq(resolve_host_ipv4(str_from("")),                          0 - 1, "resolve: empty");
    assert_eq(resolve_host_ipv4(str_from("definitely.not.in.hosts.invalid")), 0 - 1, "resolve: unknown name");
    assert_eq(resolve_host_ipv4(str_from("::1")),                       0 - 1, "resolve: IPv6 deferred");

    # is_localhost_target retained for callers — still works.
    assert_eq(is_localhost_target(str_from("127.0.0.1")), 1, "is_localhost_target: 127.0.0.1");
    assert_eq(is_localhost_target(str_from("example.com")), 0, "is_localhost_target: rejects example.com");
    assert_eq(is_localhost_target(str_from("localhost.attacker.com")), 0, "is_localhost_target: subdomain trick");

    # End-to-end TCP: an unresolvable host yields a clear failure
    # with the resolver message — not a silent connect to 127.0.0.1.
    var hc = alloc(sizeof(HealthCheck));
    store64(hc, HC_TCP_CONNECT);
    store64(hc + 8, str_from("definitely.not.in.hosts.invalid"));
    store64(hc + 16, 80);
    store64(hc + 24, 0);
    store64(hc + 32, 100);
    store64(hc + 40, 0);
    var r = execute_health_check(str_from("svc"), hc, 0);
    assert_eq(load64(r + 16), 0, "high1: TCP unresolvable = not passed");
    var msg_a = load64(r + 32);
    assert(str_contains(msg_a, str_from("did not resolve")), "high1: TCP message names resolver miss");

    # End-to-end HTTP: same shape against a host that doesn't resolve.
    var hc2 = alloc(sizeof(HealthCheck));
    store64(hc2,      HC_HTTP_GET);
    store64(hc2 + 8,  str_from("http://definitely.not.in.hosts.invalid/healthz"));
    store64(hc2 + 16, 0);
    store64(hc2 + 24, 0);
    store64(hc2 + 32, 100);
    store64(hc2 + 40, 0);
    var r2 = execute_health_check(str_from("svc"), hc2, 0);
    assert_eq(load64(r2 + 16), 0, "high1: HTTP unresolvable = not passed");
    var msg_b = load64(r2 + 32);
    assert(str_contains(msg_b, str_from("did not resolve")), "high1: HTTP message names resolver miss");

    # A resolvable-but-unconnectable target (RFC 5737 TEST-NET-1)
    # gets past the resolver, hits the connect path, and the
    # message reports a connect failure rather than a resolver
    # miss — proves the wiring distinguishes the two failure modes.
    var hc3 = alloc(sizeof(HealthCheck));
    store64(hc3, HC_TCP_CONNECT);
    store64(hc3 + 8, str_from("192.0.2.1"));
    store64(hc3 + 16, 1);            # port 1, certainly closed
    store64(hc3 + 24, 0);
    store64(hc3 + 32, 50);            # short timeout
    store64(hc3 + 40, 0);
    var r3 = execute_health_check(str_from("svc"), hc3, 0);
    assert_eq(load64(r3 + 16), 0, "high1: TCP unreachable = not passed");
    var msg_c = load64(r3 + 32);
    assert(str_contains(msg_c, str_from("connect")), "high1: TCP message distinguishes connect failure");

    # =====================================================================
    # M1 — sd_notify SO_PEERCRED check (notify_try_recv_authenticated)
    # =====================================================================
    test_group("audit-m1-notify-cred");

    # socketpair(AF_UNIX=1, SOCK_DGRAM=2, 0, &fds)
    var fds[8];
    var sp = syscall(53, 1, 2, 0, &fds);
    if (sp == 0) {
        var rfd = load32(&fds);
        var sfd = load32(&fds + 4);

        # Enable SO_PASSCRED on receiver so kernel attaches SCM_CREDENTIALS.
        var one[4];
        store32(&one, 1);
        syscall(54, rfd, 1, 16, &one, 4);   # setsockopt(SOL_SOCKET=1, SO_PASSCRED=16)

        # Send a notify datagram from sfd; kernel stamps sender PID.
        var msg = "READY=1\n";
        syscall(44, sfd, msg, 8, 0, 0, 0);   # sendto(sfd, msg, 8, 0, NULL, 0)

        # Recv with expected = [my_pid] → cred matches → parse + return msg.
        var my_pid = sys_getpid();
        var ok_pids = vec_new();
        vec_push(ok_pids, my_pid);
        var nm_ok = notify_try_recv_authenticated(rfd, ok_pids);
        assert(nm_ok != 0, "m1: cred-matched datagram parsed");
        assert_eq(load64(nm_ok), 1, "m1: parsed READY=1");

        # Send again; recv with wrong pid set → drop, return 0.
        syscall(44, sfd, msg, 8, 0, 0, 0);
        var bad_pids = vec_new();
        vec_push(bad_pids, my_pid + 99999);
        var nm_bad = notify_try_recv_authenticated(rfd, bad_pids);
        assert_eq(nm_bad, 0, "m1: cred-mismatched datagram dropped");

        # Empty queue → 0.
        var nm_empty = notify_try_recv_authenticated(rfd, ok_pids);
        assert_eq(nm_empty, 0, "m1: empty queue returns 0");

        sys_close(rfd);
        sys_close(sfd);
    }

    # pid_in_vec sanity (decoupled from socketpair availability)
    var pv = vec_new();
    vec_push(pv, 100);
    vec_push(pv, 200);
    assert_eq(pid_in_vec(pv, 100), 1, "m1: pid_in_vec hit head");
    assert_eq(pid_in_vec(pv, 200), 1, "m1: pid_in_vec hit tail");
    assert_eq(pid_in_vec(pv, 300), 0, "m1: pid_in_vec miss");
    assert_eq(pid_in_vec(0, 100),  0, "m1: pid_in_vec rejects null vec");

    # =====================================================================
    # M3 — generic-waitpid reaper for orphans (proc_table_reap_orphans)
    # =====================================================================
    test_group("audit-m3-reaper-orphans");

    # Enrol as subreaper so the grandchild orphans up to us, not init.
    syscall(157, 36, 1, 0, 0, 0);   # SYS_prctl(PR_SET_CHILD_SUBREAPER=36, 1)

    var fpid = sys_fork();
    if (fpid == 0) {
        # Child: fork grandchild, then exit immediately so grandchild orphans.
        var gc = sys_fork();
        if (gc == 0) {
            # Grandchild: sleep 50ms so child exits first, then exit.
            var ts[16];
            store64(&ts, 0);
            store64(&ts + 8, 50000000);
            syscall(35, &ts, 0);
            sys_exit(0);
        }
        sys_exit(0);
    }

    # Parent: reap our direct child immediately.
    var st_c[8];
    sys_waitpid(fpid, &st_c, 0);

    # Wait long enough for the grandchild to also exit.
    var ts2[16];
    store64(&ts2, 0);
    store64(&ts2 + 8, 200000000);   # 200ms
    syscall(35, &ts2, 0);

    var n_orphans = proc_table_reap_orphans();
    assert(n_orphans >= 1, "m3: orphan reaped via waitpid(-1)");

    # Idempotent: second call with no waiters → 0; bounded loop, no hang.
    var n_empty = proc_table_reap_orphans();
    assert_eq(n_empty, 0, "m3: empty queue returns 0");

    # =====================================================================
    # L3 — fork_exec_service setsid (child becomes session leader)
    # =====================================================================
    test_group("audit-l3-fork-setsid");

    # Validate the platform setsid syscall used by fork_exec_service:
    # in a forked child, after syscall(112), getsid(0) returns the
    # child's own PID — i.e. the child became a session leader and is
    # now decoupled from any controlling TTY inherited from the parent.
    # End-to-end verification that fork_exec_service actually invokes
    # setsid before exec is gated on the QEMU PID-1 harness in 1.6.0
    # (the existing exec_env Str/cstr quirk noted in health_exec.tcyr
    # blocks unit-level shell exec testing).
    var sid_path = "/tmp/argonaut-l3-sid";
    syscall(87, sid_path);

    var l3_pid = sys_fork();
    if (l3_pid == 0) {
        syscall(112);                     # SYS_setsid
        var sid = syscall(124, 0);        # SYS_getsid(0)
        var sfd = sys_open(sid_path, 65, 384);   # O_WRONLY|O_CREAT, 0o600
        if (sfd >= 0) {
            var sbuf[24];
            var sl = fmt_int_buf(sid, &sbuf);
            sys_write(sfd, &sbuf, sl);
            sys_close(sfd);
        }
        sys_exit(0);
    }
    var st_l[8];
    sys_waitpid(l3_pid, &st_l, 0);

    var rb = alloc(64);
    var rn = file_read_all(sid_path, rb, 64);
    assert(rn > 0, "l3: child wrote sid file");
    var rs = str_to_int(str_new(rb, rn));
    assert_eq(rs, l3_pid, "l3: setsid → child sid == child pid");

    syscall(87, sid_path);

    # =====================================================================
    # 1.5.5 closeout audit (docs/audit/2026-05-10-audit.md)
    # =====================================================================

    test_group("closeout-medium1-etc-hosts-stable-buf");

    # MEDIUM-1: lookup_etc_hosts() must reuse a single static buffer
    # rather than alloc()ing 8 KB per call. Probe by capturing the
    # buffer pointer after a baseline call, then asserting it
    # doesn't move on repeated calls. (Earlier groups in this
    # suite — `audit-high1-resolver` — already triggered the first
    # alloc, so we don't assert `== 0` pre-call; the contract under
    # test is "stable across calls", not "lazy first alloc".)
    resolve_host_ipv4(str_from("localhost"));
    var p1 = _etc_hosts_buf_ptr();
    assert(p1 != 0, "M1: buf populated after lookup");
    var i_m1 = 0;
    while (i_m1 < 100) {
        resolve_host_ipv4(str_from("localhost"));
        i_m1 = i_m1 + 1;
    }
    var p2 = _etc_hosts_buf_ptr();
    assert_eq(p1, p2, "M1: buf ptr stable across 100 lookups");

    test_group("closeout-medium2-persist-disk-fail");

    # MEDIUM-2: audit_log_record_persistent must return 0 when the
    # patrastore append fails. Force the failure by passing a
    # PersistentAuditLog with a poisoned store handle (a sentinel
    # value the audit_ext recognises as "force-fail" — see the
    # `_audit_ext_test_force_disk_fail` helper that flags the store).
    var pal_test = audit_log_open_persistent(str_from("/tmp/argonaut_closeout_m2.patra"));
    assert(pal_test != 0, "M2: open succeeded for setup");
    _audit_ext_test_force_disk_fail(pal_test, 1);
    var e_fail = audit_log_record_persistent(pal_test, "svc-m2", EVT_STARTING);
    assert_eq(e_fail, 0, "M2: disk-fail path returns 0");
    _audit_ext_test_force_disk_fail(pal_test, 0);
    var e_ok = audit_log_record_persistent(pal_test, "svc-m2", EVT_STARTED);
    assert(e_ok != 0, "M2: clean-path still returns entry");
    audit_log_close_persistent(pal_test);
    syscall(87, str_data(str_from("/tmp/argonaut_closeout_m2.patra")));

    test_group("closeout-medium3-persist-tamper-rejected");

    # MEDIUM-3: open must verify chain integrity on replay. Build a
    # 3-entry log, close, mutate one stored entry's details field
    # directly via patra so the chain hash no longer holds, reopen
    # and assert it returns 0 (verify rejected). The mutation
    # helper `_audit_ext_test_mutate_first_detail` performs the
    # in-place SQL update bypassing the audit_log_record API.
    var m3_path = str_from("/tmp/argonaut_closeout_m3.patra");
    syscall(87, str_data(m3_path));
    var m3_pal = audit_log_open_persistent(m3_path);
    audit_log_record_persistent(m3_pal, "svc-m3", EVT_STARTING);
    audit_log_record_persistent(m3_pal, "svc-m3", EVT_STARTED);
    audit_log_record_persistent(m3_pal, "svc-m3", EVT_STOPPED_OK);
    audit_log_flush_persistent(m3_pal);
    audit_log_close_persistent(m3_pal);

    _audit_ext_test_mutate_first_detail(m3_path);

    var m3_pal2 = audit_log_open_persistent(m3_path);
    assert_eq(m3_pal2, 0, "M3: tampered chain rejected on open");
    syscall(87, str_data(m3_path));

    test_group("closeout-low2-http-port-range");

    # LOW-2: HTTP_GET branch must reject port > 65535 with a clear
    # message rather than silent connect-fail on a wraparound port.
    var hc_p = alloc(sizeof(HealthCheck));
    store64(hc_p,      HC_HTTP_GET);
    store64(hc_p + 8,  str_from("http://localhost:99999/healthz"));
    store64(hc_p + 16, 0);
    store64(hc_p + 24, 0);
    store64(hc_p + 32, 100);
    store64(hc_p + 40, 0);
    var r_p = execute_health_check(str_from("svc"), hc_p, 0);
    assert_eq(load64(r_p + 16), 0, "L2: out-of-range port = not passed");
    var msg_p = load64(r_p + 32);
    assert(str_contains(msg_p, str_from("port out of range")), "L2: message names port-range failure");

    test_group("closeout-low3-http-host-crlf");

    # LOW-3: defense-in-depth. The resolver gate already blocks
    # CRLF-containing hosts at parse_ipv4 / /etc/hosts lookup, but
    # `sanitize_host_for_header` is a separate gate so a future
    # refactor that skips the resolver doesn't re-open the injection.
    assert_eq(sanitize_host_for_header(str_from("localhost")),       1, "L3: alphanumeric accepted");
    assert_eq(sanitize_host_for_header(str_from("127.0.0.1")),       1, "L3: dotted quad accepted");
    assert_eq(sanitize_host_for_header(str_from("evil\r\nHost: x")), 0, "L3: CRLF rejected");
    assert_eq(sanitize_host_for_header(str_from("evil\nGET /")),     0, "L3: bare LF rejected");
    assert_eq(sanitize_host_for_header(str_from("")),                0, "L3: empty rejected");
    # NUL embedded in a Str (cstr literals truncate at first NUL —
    # build the string by hand: "evil" + NUL + "null"). Asserts
    # sanitize_host_for_header scans by length, not by NUL terminator.
    var nul_buf = alloc(9);
    store8(nul_buf,     101);   # e
    store8(nul_buf + 1, 118);   # v
    store8(nul_buf + 2, 105);   # i
    store8(nul_buf + 3, 108);   # l
    store8(nul_buf + 4, 0);     # NUL
    store8(nul_buf + 5, 110);   # n
    store8(nul_buf + 6, 117);   # u
    store8(nul_buf + 7, 108);   # l
    store8(nul_buf + 8, 108);   # l
    var nul_str = str_new(nul_buf, 9);
    assert_eq(sanitize_host_for_header(nul_str), 0, "L3: NUL byte rejected");

    return assert_summary();
}

var r = main();
syscall(SYS_EXIT, r);
