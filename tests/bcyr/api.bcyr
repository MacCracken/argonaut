# api.bcyr — API response + resource limit benchmarks
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/process.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"
include "lib/args.cyr"
include "lib/bench.cyr"
include "lib/sakshi_full.cyr"

include "src/types.cyr"
include "src/boot.cyr"
include "src/services.cyr"
include "src/process_mgmt.cyr"
include "src/health.cyr"
include "src/edge_boot.cyr"
include "src/notify.cyr"
include "src/security.cyr"
include "src/systemd.cyr"
include "src/tmpfiles.cyr"
include "src/init.cyr"

fn main() {
    alloc_init();
    println("=== API + Resource Benchmarks ===\n");

    var iters = 10000;
    var benches = vec_new();
    var init = argonaut_init_new(argonaut_config_default());

    var b1 = bench_new("api_list_svcs");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b1);
        init_list_services(init);
        bench_stop(b1);
    }
    bench_report(b1);
    vec_push(benches, b1);

    var b2 = bench_new("api_sys_status");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b2);
        init_system_status(init);
        bench_stop(b2);
    }
    bench_report(b2);
    vec_push(benches, b2);

    var b3 = bench_new("api_sys_metrics");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b3);
        init_system_metrics(init);
        bench_stop(b3);
    }
    bench_report(b3);
    vec_push(benches, b3);

    var b4 = bench_new("api_boot_log");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b4);
        init_boot_log(init);
        bench_stop(b4);
    }
    bench_report(b4);
    vec_push(benches, b4);

    var rl = alloc(sizeof(ResourceLimits));
    store64(rl, 1024);
    store64(rl + 8, 1073741824);
    store64(rl + 16, 512);
    store64(rl + 24, 0);
    var b5 = bench_new("prlimit_cmds");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b5);
        to_prlimit_commands(rl, 42);
        bench_stop(b5);
    }
    bench_report(b5);
    vec_push(benches, b5);

    var b6 = bench_new("boot_exec_plan");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b6);
        init_boot_execution_plan(init);
        bench_stop(b6);
    }
    bench_report(b6);
    vec_push(benches, b6);

    var b7 = bench_new("boot_exec_waves");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b7);
        init_boot_execution_plan_waves(init);
        bench_stop(b7);
    }
    bench_report(b7);
    vec_push(benches, b7);

    var dcmd = safe_cmd_new(str_from("/usr/bin/svc"));
    safe_cmd_add_arg(dcmd, str_from("--port"));
    safe_cmd_add_arg(dcmd, str_from("8080"));
    var b8 = bench_new("safe_cmd_disp");
    for (var i = 0; i < iters; i = i + 1) {
        bench_start(b8);
        safe_cmd_display(dcmd);
        bench_stop(b8);
    }
    bench_report(b8);
    vec_push(benches, b8);

    println("\n=== Summary ===");
    bench_report_all(benches);

    return 0;
}
var r = main();
syscall(SYS_EXIT, r);
