# =========================================================================
# Shared test helpers
# =========================================================================

fn minimal_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_MINIMAL);
    return argonaut_init_new(cfg);
}

fn server_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_SERVER);
    return argonaut_init_new(cfg);
}

fn desktop_init() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_DESKTOP);
    return argonaut_init_new(cfg);
}

fn edge_init_fn() {
    var cfg = argonaut_config_default();
    store64(cfg, BOOT_EDGE);
    return argonaut_init_new(cfg);
}

fn steps_has_stage(steps, stage) {
    for (var i = 0; i < vec_len(steps); i = i + 1) {
        if (load64(vec_get(steps, i)) == stage) { return 1; }
    }
    return 0;
}

fn svcs_has_name(svcs, name) {
    for (var i = 0; i < vec_len(svcs); i = i + 1) {
        if (streq(str_data(svc_def_name(vec_get(svcs, i))), name)) { return 1; }
    }
    return 0;
}

fn order_pos(order, name) {
    for (var i = 0; i < vec_len(order); i = i + 1) {
        if (streq(str_data(vec_get(order, i)), name)) { return i; }
    }
    return 0 - 1;
}

fn vec_contains_str(v, s) {
    var target = str_data(s);
    for (var i = 0; i < vec_len(v); i = i + 1) {
        if (streq(str_data(vec_get(v, i)), target)) { return 1; }
    }
    return 0;
}

fn dummy_svc(name, deps) {
    var sd = svc_def_new(name, str_cat(str_from("test "), name), str_cat(str_from("/usr/bin/"), name));
    store64(sd + 56, RESTART_NEVER);
    vec_push(svc_def_modes(sd), BOOT_MINIMAL);
    if (deps != 0) {
        for (var i = 0; i < vec_len(deps); i = i + 1) {
            vec_push(svc_def_deps(sd), vec_get(deps, i));
        }
    }
    return sd;
}
